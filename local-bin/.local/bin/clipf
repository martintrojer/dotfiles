#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: clipf <path>

Copy a file's contents to the system clipboard.
Preserves MIME type for images/PDFs where supported.
EOF
}

if [[ $# -eq 1 && ( "$1" == "-h" || "$1" == "--help" ) ]]; then
  usage
  exit 0
fi

if [[ $# -ne 1 ]]; then
  usage >&2
  exit 2
fi

path="$1"
mime="$(file -bL --mime-type "$path")"

if [[ "$OSTYPE" == "darwin"* ]]; then
  if [[ "$mime" == image/* || "$mime" == "application/pdf" ]]; then
    osascript -e "set the clipboard to (read (POSIX file \"$path\") as «class furl»)"
  else
    pbcopy < "$path"
  fi
elif [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]]; then
  wl-copy -t "$mime" < "$path"
else
  xclip -selection clipboard -t "$mime" -i "$path"
fi
