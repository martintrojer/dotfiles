# Cherry-picked from oh-my-zsh mercurial plugin. Used at $WORK only
# (this machine never runs hg), so the alias set is small and matches
# what showed up in the macOS zsh_history.
#
# OMZ's mercurial plugin ships ~25 aliases; we use 6.

alias hga='hg add'
alias hgc='hg commit'
alias hgca='hg commit --amend'
alias hgco='hg checkout'
alias hgd='hg diff'
alias hgs='hg status'
