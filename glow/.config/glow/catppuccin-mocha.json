{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "#74c7ec",
    "italic": true
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#cba6f7",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#11111b",
    "background_color": "#cba6f7",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#74c7ec",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "#89b4fa",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "#89dceb"
  },
  "h5": {
    "prefix": "##### ",
    "color": "#94e2d5"
  },
  "h6": {
    "prefix": "###### ",
    "color": "#a6e3a1",
    "italic": true
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true,
    "color": "#6c7086"
  },
  "emph": {
    "italic": true,
    "color": "#f9e2af"
  },
  "strong": {
    "bold": true,
    "color": "#fab387"
  },
  "hr": {
    "color": "#6c7086",
    "format": "\n──────────────────────────────────────────\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#89b4fa",
    "underline": true
  },
  "link_text": {
    "color": "#89dceb",
    "bold": true
  },
  "image": {
    "color": "#f5c2e7",
    "underline": true
  },
  "image_text": {
    "color": "#f5c2e7",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "color": "#f38ba8",
    "background_color": "#313244",
    "prefix": " ",
    "suffix": " "
  },
  "code_block": {
    "color": "#cdd6f4",
    "margin": 2,
    "chroma": {
      "text":             { "color": "#cdd6f4" },
      "error":            { "color": "#f38ba8" },
      "comment":          { "color": "#6c7086", "italic": true },
      "comment_preproc":  { "color": "#cba6f7" },
      "keyword":          { "color": "#cba6f7" },
      "keyword_reserved": { "color": "#cba6f7" },
      "keyword_namespace":{ "color": "#cba6f7" },
      "keyword_type":     { "color": "#f9e2af" },
      "operator":         { "color": "#89dceb" },
      "punctuation":      { "color": "#cdd6f4" },
      "name":             { "color": "#cdd6f4" },
      "name_builtin":     { "color": "#fab387" },
      "name_tag":         { "color": "#cba6f7" },
      "name_attribute":   { "color": "#f9e2af" },
      "name_class":       { "color": "#f9e2af" },
      "name_constant":    { "color": "#fab387" },
      "name_decorator":   { "color": "#89b4fa" },
      "name_exception":   { "color": "#f38ba8" },
      "name_function":    { "color": "#89b4fa" },
      "name_other":       { "color": "#cdd6f4" },
      "literal":          { "color": "#fab387" },
      "literal_number":   { "color": "#fab387" },
      "literal_date":     { "color": "#fab387" },
      "literal_string":            { "color": "#a6e3a1" },
      "literal_string_escape":     { "color": "#f5c2e7" },
      "literal_string_interpol":   { "color": "#f5c2e7" },
      "literal_string_symbol":     { "color": "#a6e3a1" },
      "generic_deleted":  { "color": "#f38ba8" },
      "generic_emph":     { "italic": true },
      "generic_inserted": { "color": "#a6e3a1" },
      "generic_strong":   { "bold": true },
      "generic_subheading": { "color": "#cba6f7" },
      "background":       { "background_color": "#313244" }
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {
    "color": "#fab387",
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n  "
  },
  "html_block": {},
  "html_span": {}
}
