#!/usr/bin/env bash
set -euo pipefail

# Embedded "SteamOS Gaming Mode" session: a gamescope session on the DRM/KMS
# backend that owns the display directly and drives true HDR10 — what the Sway
# desktop can't do under Sway < 1.12. See fedora/gaming/docs/HDR-GAMING.md.
#
# Picked as "Steam (gamescope)" at the SDDM login screen; the session entry
# (steam.desktop) execs this script. Installed by config/setup-gamescope-session.sh.
#
# In gamepad UI the power menu has no "Exit Steam"; the way out is "Desktop
# Mode", which calls `steamos-session-select` on PATH. The stowed shim
# (~/.local/bin/steamos-session-select) ends the session and returns to SDDM,
# since we have no desktop-in-gamescope target. The PATH export below makes the
# gamepad UI find it.
#
# This session runs Steam's gamepad UI cleanly under gamescope. Per-game Proton,
# OptiScaler, and FSR4 tweaks should stay in Steam launch options; applying them
# to Steam itself can break the CEF-rendered UI and leave the gamescope viewport
# black. Under the Sway desktop none of this applies.
#
# Keep only the HDR WSI environment here, because Steam/game launches inherit it
# and gamescope needs it for Vulkan HDR negotiation.
#
# A game that dislikes HDR can still override it via Steam launch options, since
# those env vars expand before %command%, e.g. `DXVK_HDR=0 %command%`.
#
# Knobs (the monitor here is fixed 4K@60 HDR, so defaults rarely need changing):
#   GS_OUT_W   output width   (default 3840)
#   GS_OUT_H   output height  (default 2160)
#   GS_REFRESH refresh rate   (default 60)
#   GS_HDR     HDR output (default on); set GS_HDR=0 to disable
#   GS_ARGS    extra gamescope args appended verbatim
#   GS_SUNSHINE  start the Sunshine stream host for this session (default off)

# Refuse to run nested: the DRM backend needs to own the display. This only makes
# sense as an SDDM session, not from inside Sway.
if [[ -n "${WAYLAND_DISPLAY:-}" || -n "${DISPLAY:-}" ]]; then
  echo "steam-session: refusing to run inside a graphical session." \
       "Pick 'Steam (gamescope)' at the SDDM login screen instead." >&2
  exit 1
fi

# SDDM launches this via a non-interactive login shell, so ~/.zshrc (which puts
# ~/.local/bin on PATH and activates mise) is never sourced, and the
# environment.d PATH addition isn't reliably imported either. The result is the
# bare login PATH, so anything Steam spawns that relies on ~/.local/bin would
# fail with "command not found". Ensure the dir is on PATH here; the whole session
# tree (Steam and everything it spawns) inherits it.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

# No MANGOHUD_CONFIGFILE here: in SteamOS game mode (-steamos3) Steam drives the
# --mangoapp overlay via its control socket (the Quick Access "Performance"
# panel), rewriting the config at runtime. We used to point mangoapp at a stowed
# config, but Steam clobbers it, so the overlay is Steam's to own now.

args=(--backend drm
  -W "${GS_OUT_W:-3840}" -H "${GS_OUT_H:-2160}" -r "${GS_REFRESH:-60}"
  -f --mangoapp -e)

[[ "${GS_HDR:-1}" != "0" ]] && args+=(--hdr-enabled)

# shellcheck disable=SC2206  # word-splitting GS_ARGS is intentional
[[ -n "${GS_ARGS:-}" ]] && args+=($GS_ARGS)

# Build the gamescope command. HDR sessions negotiate HDR via the gamescope WSI
# layer; SDR sessions don't set the HDR WSI env.
#
# Launch flags: `-steamos3` (not just `-gamepadui`) is required for the power
# menu's "Desktop Mode" to work. That button's handler only runs the legacy
# `steam-runtime-launch-client -- steamos-session-select` exec when Steam
# believes it's in SteamOS game mode (Plat_IsSteamOSGameMode); with `-gamepadui`
# alone the button opens its modal but execs nothing and hangs. `-steamos3`
# selects the SteamOS 3 game-mode behaviour (in-UI network/Bluetooth, the
# session lifecycle, the Switch-to-Desktop exec); our steamos-session-select
# shim is the fallback taken because no SteamOSManager1 D-Bus service exists.
#
# We deliberately do NOT pass `-steamdeck`: that's the handheld hardware profile
# (battery UI, deck controller/OSK, LCD/OLED/fan assumptions), wrong for this
# couch "Steam Machine". If Desktop Mode still no-ops without `-steamdeck`, add
# it back — but `-steamos3` alone should gate the game-mode exec path.
steam_args=(-steamos3 -gamepadui)
if [[ "${GS_HDR:-1}" != "0" ]]; then
  cmd=(gamescope "${args[@]}" -- env DXVK_HDR=1 ENABLE_GAMESCOPE_WSI=1 steam "${steam_args[@]}")
else
  cmd=(gamescope "${args[@]}" -- steam "${steam_args[@]}")
fi

# Stream session (GS_SUNSHINE=1): run Sunshine so a Moonlight client can
# KMS-capture this session's scanout. The rpm's unit is never `enable`d, so it
# runs only when started here. No `exec`: the script must outlive gamescope to
# stop Sunshine on quit. See fedora/gaming/docs/STREAMING.md.
sunshine_unit=app-dev.lizardbyte.app.Sunshine.service
if [[ "${GS_SUNSHINE:-0}" == "1" ]]; then
  systemctl --user start "$sunshine_unit" || \
    echo "steam-session: failed to start $sunshine_unit" >&2
  trap 'systemctl --user stop "$sunshine_unit"' EXIT
  "${cmd[@]}"
  exit $?
fi

exec "${cmd[@]}"
