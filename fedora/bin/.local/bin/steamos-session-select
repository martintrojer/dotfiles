#!/usr/bin/env bash
set -euo pipefail

# Shim for Steam's gamepad UI "Desktop Mode" button, which shells out to
# `steamos-session-select <target>` on $PATH (no plain "Exit Steam" exists in
# gamepad UI). We have no desktop-in-gamescope target, so ignore the target and
# just end the session to land back at SDDM. steam-session puts ~/.local/bin on
# PATH so the gamepad UI finds this. See fedora/docs/HDR-GAMING.md.

# Ask Steam to shut down cleanly first (flushes cloud saves, closes the UI).
steam -shutdown >/dev/null 2>&1 || true

# End the graphical session so SDDM takes back the seat. Prefer the specific
# session id; fall back to terminating the user's sessions.
if [[ -n "${XDG_SESSION_ID:-}" ]]; then
  loginctl terminate-session "$XDG_SESSION_ID" 2>/dev/null && exit 0
fi
loginctl terminate-user "$USER" 2>/dev/null || true
