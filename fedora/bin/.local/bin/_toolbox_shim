#!/usr/bin/env python3
"""Find ``<command>`` on PATH (excluding the shim's own dir to avoid
recursion) and exec it; fall back to ``toolbox run -c <toolbox>``
on Fedora-family Linux.

Called as ``_toolbox_shim <toolbox> <command> [args...]`` by the
tiny wrappers under ``fedora/bin/.local/bin/`` (``cava``, ``ollama``).
"""

from __future__ import annotations

import os
import shutil
import sys
from pathlib import Path


def find_outside_shim_dir(command: str) -> str | None:
    """Locate ``command`` on PATH, skipping the shim's own dir to
    avoid recursion. Match the invocation path (not the symlink
    target) so the stowed ``~/.local/bin/`` entry gets excluded.
    """
    shim_dir = str(Path(sys.argv[0]).absolute().parent)
    raw_path = os.environ.get("PATH", "")
    candidates = [p for p in raw_path.split(os.pathsep) if p and p != shim_dir]
    return shutil.which(command, path=os.pathsep.join(candidates))


def is_fedora_family() -> bool:
    if sys.platform != "linux":
        return False
    try:
        text = Path("/etc/os-release").read_text(encoding="utf-8")
    except OSError:
        return False
    ids: list[str] = []
    for line in text.splitlines():
        if "=" not in line:
            continue
        key, _, value = line.partition("=")
        if key in ("ID", "ID_LIKE"):
            ids.extend(value.strip().strip('"').lower().split())
    return any(name in {"fedora", "rhel"} for name in ids)


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        prog = Path(sys.argv[0]).name
        print(f"Usage: {prog} <toolbox> <command> [args...]", file=sys.stderr)
        return 2

    toolbox_name, tool_name, *passthrough = argv

    if (real_cmd := find_outside_shim_dir(tool_name)) is not None:
        os.execv(real_cmd, [real_cmd, *passthrough])

    if shutil.which("toolbox") is None:
        print(
            f"Command not found: {tool_name}, and toolbox is unavailable",
            file=sys.stderr,
        )
        return 127

    if is_fedora_family():
        os.execvp(
            "toolbox", ["toolbox", "run", "-c", toolbox_name, tool_name, *passthrough]
        )

    print(f"Command not found: {tool_name}", file=sys.stderr)
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
