#!/usr/bin/env python3
"""Wallpaper helper for sway/swaybg + lock-screen.

Owns everything to do with wallpapers: storage, the `current` symlink
that swaybg consumes, and the rendered "lock" image (blurred + banner-
stamped + accent-colored) that lock-screen consumes via the JSON
emitted by `wallpaper status`.

Subcommands
-----------
  set <url-or-file>     Download (curl) or copy a wallpaper into the
                        archive, snapshot the previous current if it
                        wasn't already an archive entry, activate,
                        restart swaybg.service, and pre-render the
                        lock image so the next lock is instant.
  use [archive-file]    Activate an existing archive entry. Without an
                        argument: open an fzf picker. Argument can be a
                        bare basename or a full path. Also pre-renders
                        the lock image.
  current               Print the resolved path of the active wallpaper
                        as plain text. Used by swaybg / scripts that
                        only want the source path. Fast (pure symlink
                        read).
  status                Print JSON describing the active wallpaper plus
                        derived state for the lock screen:
                          { "path": ..., "lock_image": ..., "accent": ... }
                        Returns exit 1 with empty JSON if no wallpaper.
                        Pure cache read; doesn't render on demand. Used
                        by lock-screen.
  restart               Restart swaybg.service.
  preview <file>        Render via chafa for fzf's preview pane.
  rebuild-cache         Force-rebuild the lock image + accent for the
                        current wallpaper. Useful after editing the
                        render constants in this file.

Why this is Python
------------------
Was 305 lines of bash with `declare -g` global contracts, `set -u`
tripping on `local`-shadowed-globals, tab-separated `mktemp` templates
parsed by `read`, and quoted-eval gymnastics for filename sanitization.
Per AGENTS.md "Shell vs Python rule": got moved to Python. Then absorbed
the lock-image rendering + accent-color picking from sway/scripts/
lock-screen so all ImageMagick code lives here — lock-screen just calls
`wallpaper status` and execs swaylock with the result.
"""
from __future__ import annotations

import argparse
import colorsys
import hashlib
import json
import os
import re
import shutil
import socket
import string
import subprocess
import sys
import tempfile
import time
from datetime import datetime
from pathlib import Path
from urllib.parse import urlparse


# ----------------------------------------------------------------------
# Paths (single source of truth; no global-shadowing footguns)
# ----------------------------------------------------------------------

XDG_DATA_HOME = Path(os.environ.get("XDG_DATA_HOME") or Path.home() / ".local" / "share")
XDG_CACHE_HOME = Path(os.environ.get("XDG_CACHE_HOME") or Path.home() / ".cache")
XDG_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or Path.home() / ".config")

TARGET_DIR = XDG_DATA_HOME / "wallpapers"
ARCHIVE_DIR = TARGET_DIR / "archive"
CURRENT_LINK = TARGET_DIR / "current"
CACHE_DIR = XDG_CACHE_HOME / "wallpaper"

# Fallback location read by `wallpaper current` only (legacy compat).
FALLBACK_CURRENT = XDG_CONFIG_HOME / "wallpapers" / "current"


# ----------------------------------------------------------------------
# Lock-image render recipe (was previously flags on lock-screen).
#
# Bake-in instead of expose because pillar #4 — the flags weren't
# earning their keep, the values stabilized months ago, and tweaking
# requires editing this file (which invalidates the cache via
# RENDER_VERSION below).
# ----------------------------------------------------------------------

BLUR_SIGMA = 18.0
# Multiply plucked-color saturation by this so the accent reads as
# wallpaper-derived rather than neon. 1.0 = take what the wallpaper
# gives you; 0.85 takes the edge off without losing identity.
SATURATION_SCALE = 0.85
FONT = "JetBrainsMono-NF-Bold"
# Bump when changing anything that affects the rendered PNG (font,
# pointsizes, blur recipe, banner geometry). The cache key folds this
# in, so changes invalidate cached images automatically.
RENDER_VERSION = 2
# Catppuccin Mocha 'text' — banner fallback when accent pluck fails.
FALLBACK_TEXT_COLOR = "cdd6f4"
# Cache eviction horizon. Entries untouched for this long get pruned
# on the next cache-touching invocation.
CACHE_PRUNE_DAYS = 30

# Match lines like:  "  1962: (92,37,12) #5C250C srgb(...)"
_HIST_RE = re.compile(r"^\s*(\d+):.*#([0-9A-Fa-f]{6})")


# ----------------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------------

_STEM_KEEP = set(string.ascii_letters + string.digits + "._-")


def die(msg: str, code: int = 1) -> "subprocess.NoReturn":  # type: ignore[name-defined]
    print(f"wallpaper: {msg}", file=sys.stderr)
    raise SystemExit(code)


def sanitize_stem(name: str) -> tuple[str, str]:
    """Split a basename into (sanitized_stem, ext_with_dot).

    Mirrors the bash version: keep ASCII letters, digits, dot, underscore,
    hyphen; replace everything else with '-' and squash repeats; strip
    leading/trailing '-'; fall back to 'wallpaper' if the result is empty.
    A leading dot makes the whole thing a stem with no extension.
    """
    if "." in name and not name.startswith("."):
        stem, _, ext = name.rpartition(".")
        ext = "." + ext
    else:
        stem, ext = name, ""

    out: list[str] = []
    last_dash = False
    for ch in stem:
        if ch in _STEM_KEEP:
            out.append(ch)
            last_dash = False
        elif not last_dash:
            out.append("-")
            last_dash = True
    sanitized = "".join(out).strip("-") or "wallpaper"
    return sanitized, ext


def basename_from_url_or_path(src: str) -> str:
    """Strip URL query string before taking basename, leave file paths alone."""
    parsed = urlparse(src)
    if parsed.scheme in ("http", "https", "ftp", "file"):
        return Path(parsed.path).name or "wallpaper"
    return Path(src).name


def make_archive_path(stem: str, ext: str, timestamp: str | None = None) -> Path:
    """Allocate a unique filename under ARCHIVE_DIR using mkstemp.

    Format: <YYYYMMDD-HHMMSS>-<stem>.<6 random chars><ext>
    Matches the bash mktemp template format. mkstemp guarantees uniqueness
    even under racing callers and creates the file with mode 0600.
    """
    ts = timestamp or datetime.now().strftime("%Y%m%d-%H%M%S")
    fd, path = tempfile.mkstemp(
        prefix=f"{ts}-{stem}.",
        suffix=ext,
        dir=str(ARCHIVE_DIR),
    )
    os.close(fd)
    return Path(path)


def ensure_dirs() -> None:
    ARCHIVE_DIR.mkdir(parents=True, exist_ok=True)


def require_systemctl() -> None:
    if shutil.which("systemctl") is None:
        die("systemctl is unavailable")


def restart_swaybg() -> None:
    require_systemctl()
    if subprocess.run(["systemctl", "--user", "restart", "swaybg.service"]).returncode != 0:
        die("failed to restart swaybg.service")


# ----------------------------------------------------------------------
# Lock-image cache: blurred + banner-stamped PNG + plucked accent color
#
# Files live at $XDG_CACHE_HOME/wallpaper/<sha>.{png,color}. Key is
# wallpaper path + mtime + RENDER_VERSION; bumping the version (or
# editing the source wallpaper) invalidates the entry automatically.
#
# Lock-screen reads these via `wallpaper status`. Wallpaper set/use
# pre-render so the next lock is instant.
# ----------------------------------------------------------------------


def _cache_key(wallpaper: Path) -> str | None:
    """Stable key derived from absolute path + mtime + RENDER_VERSION."""
    try:
        mtime = wallpaper.stat().st_mtime_ns
    except OSError:
        return None
    raw = f"{wallpaper}\0{mtime}\0v={RENDER_VERSION}".encode()
    return hashlib.sha1(raw).hexdigest()[:16]


def _cache_paths(wallpaper: Path) -> tuple[Path, Path] | None:
    key = _cache_key(wallpaper)
    if key is None:
        return None
    return CACHE_DIR / f"{key}.png", CACHE_DIR / f"{key}.color"


def _touch(path: Path) -> None:
    """Best-effort mtime bump so the prune step keeps active entries warm."""
    try:
        path.touch()
    except OSError:
        pass


def _prune_cache() -> None:
    """Drop cache entries untouched for more than CACHE_PRUNE_DAYS."""
    if CACHE_PRUNE_DAYS <= 0 or not CACHE_DIR.is_dir():
        return
    cutoff = CACHE_PRUNE_DAYS * 86400
    now = time.time()
    for entry in CACHE_DIR.iterdir():
        try:
            if entry.is_file() and (now - entry.stat().st_mtime) > cutoff:
                entry.unlink()
        except OSError:
            pass


def _pick_accent(src: Path) -> str | None:
    """Quantize wallpaper to 16 colors; pick the most-prominent vivid one.

    Score = count * saturation^1.5 * brightness-near-mid. Winner is then
    desaturated by SATURATION_SCALE so it reads as an accent rather than
    a neon stripe. Returns 6-char hex (no #) or None on failure.
    """
    if not shutil.which("magick"):
        return None
    try:
        res = subprocess.run(
            [
                "magick", str(src),
                "-resize", "200x200",
                "-colors", "16",
                "-depth", "8",
                "-format", "%c",
                "histogram:info:-",
            ],
            capture_output=True,
            text=True,
            timeout=15,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if res.returncode != 0:
        return None

    best: tuple[float, float, float, float] | None = None  # (score, h, l, s)
    for line in res.stdout.splitlines():
        m = _HIST_RE.match(line)
        if not m:
            continue
        count = int(m.group(1))
        hexv = m.group(2).lower()
        r, g, b = (int(hexv[i : i + 2], 16) / 255 for i in (0, 2, 4))
        hue, lightness, sat = colorsys.rgb_to_hls(r, g, b)
        bright = max(0.0, 1 - abs(lightness - 0.55) * 1.4)
        score = count * (sat**1.5) * bright
        if score <= 0:
            continue
        if best is None or score > best[0]:
            best = (score, hue, lightness, sat)

    if best is None:
        return None
    _, hue, lightness, sat = best
    r, g, b = colorsys.hls_to_rgb(hue, lightness, sat * SATURATION_SCALE)
    return "{:02x}{:02x}{:02x}".format(round(r * 255), round(g * 255), round(b * 255))


def _build_lock_image(src: Path, dst: Path, *, accent: str | None) -> bool:
    """Render blurred + banner-stamped wallpaper to dst.

    Blur is applied first so the banner stays sharp. Banner is two
    centered stacked lines (LOCKED / user@host) with a 2px dark drop-
    shadow underneath each line so the text stays legible against light
    wallpapers. Banner fill is the plucked accent (falls back to
    Catppuccin text color).
    """
    if not shutil.which("magick"):
        return False
    line1 = "LOCKED"
    line2 = (
        f"{os.environ.get('USER', 'user')}@"
        f"{socket.gethostname().split('.')[0]}"
    )
    # y-offsets are from the bottom edge (gravity south); larger y =
    # higher up. ~52pt + ~14pt gap puts LOCKED above user@host with
    # breathing room.
    line1_y, line2_y = 152, 100
    line1_pt, line2_pt = "42", "30"
    if accent and re.fullmatch(r"[0-9a-fA-F]{6}", accent):
        fill = f"#{accent}ff"
    else:
        fill = f"#{FALLBACK_TEXT_COLOR}ff"
    shadow = "#00000099"
    cmd: list[str] = ["magick", str(src), "-blur", f"0x{BLUR_SIGMA}"]
    cmd += ["-gravity", "south", "-font", FONT]
    for text, y, pt in ((line1, line1_y, line1_pt), (line2, line2_y, line2_pt)):
        cmd += [
            "-pointsize", pt,
            "-fill", shadow, "-annotate", f"+2+{y - 2}", text,
            "-fill", fill, "-annotate", f"+0+{y}", text,
        ]
    cmd.append(str(dst))
    try:
        res = subprocess.run(cmd, capture_output=True, timeout=30, check=False)
    except (OSError, subprocess.SubprocessError):
        return False
    return res.returncode == 0 and dst.is_file() and dst.stat().st_size > 0


def build_lock_cache(wallpaper: Path, *, force: bool = False) -> tuple[Path | None, str | None]:
    """Pluck accent + render lock image for `wallpaper`. Idempotent.

    Returns (image_path, accent_hex). Either may be None if the
    corresponding step failed (no `magick` on PATH, etc.). Lock-screen
    handles those Nones via its solid-color fallback.
    """
    paths = _cache_paths(wallpaper)
    if paths is None:
        return None, None
    img_path, color_path = paths
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    _prune_cache()

    # Accent first — the rendered image bakes it into the banner, so a
    # cached image without the accent stored is meaningless.
    accent: str | None = None
    if force:
        for p in (img_path, color_path):
            p.unlink(missing_ok=True)
    if color_path.is_file() and color_path.stat().st_size > 0:
        try:
            cached = color_path.read_text().strip()
            if re.fullmatch(r"[0-9a-fA-F]{6}", cached):
                accent = cached
        except OSError:
            pass
    if accent is None:
        accent = _pick_accent(wallpaper)
        if accent:
            try:
                color_path.write_text(accent + "\n")
            except OSError:
                pass
    if accent:
        _touch(color_path)

    image: Path | None = None
    if img_path.is_file() and img_path.stat().st_size > 0:
        image = img_path
        _touch(img_path)
    elif _build_lock_image(wallpaper, img_path, accent=accent):
        image = img_path

    return image, accent


# ----------------------------------------------------------------------
# Activate (shared by `set` and `use`)
# ----------------------------------------------------------------------


def archive_existing_current() -> None:
    """Snapshot the current wallpaper into the archive, unless it already
    lives there.

    Same dance as the bash version: if `current` is a symlink, copy the
    target into the archive (preserving the source for whoever else might
    point at it). If `current` is a plain file, move it. If `current` is
    already inside ARCHIVE_DIR, no-op.
    """
    if not CURRENT_LINK.exists() and not CURRENT_LINK.is_symlink():
        return

    try:
        resolved = CURRENT_LINK.resolve(strict=True)
    except (OSError, RuntimeError):
        return

    if not resolved.is_file():
        return

    try:
        resolved.relative_to(ARCHIVE_DIR.resolve())
        return  # already in archive; nothing to snapshot
    except ValueError:
        pass

    stem, ext = sanitize_stem(resolved.name)
    archived = make_archive_path(stem, ext)
    if CURRENT_LINK.is_symlink():
        shutil.copy2(resolved, archived)
    else:
        shutil.move(str(CURRENT_LINK), archived)


def activate(archive_path: Path) -> None:
    if not archive_path.is_file():
        die(f"archive file not found: {archive_path}")

    archive_existing_current()
    if CURRENT_LINK.exists() or CURRENT_LINK.is_symlink():
        CURRENT_LINK.unlink()
    CURRENT_LINK.symlink_to(archive_path)
    restart_swaybg()
    # Pre-render the lock image so the next lock is instant. Best-effort
    # — a render failure here doesn't fail the activate; lock-screen
    # falls back to a solid-color lock when the cache is missing.
    build_lock_cache(archive_path)


# ----------------------------------------------------------------------
# Subcommands
# ----------------------------------------------------------------------


def cmd_set(args: argparse.Namespace) -> int:
    src: str = args.source
    ensure_dirs()

    source_name = basename_from_url_or_path(src)
    stem, ext = sanitize_stem(source_name)

    incoming_fd, incoming_path_str = tempfile.mkstemp(
        prefix=".incoming.", dir=str(ARCHIVE_DIR)
    )
    os.close(incoming_fd)
    incoming_path = Path(incoming_path_str)

    try:
        if Path(src).is_file():
            shutil.copy2(src, incoming_path)
        else:
            if shutil.which("curl") is None:
                die("curl is required for URL downloads")
            result = subprocess.run(["curl", "-fL", src, "-o", str(incoming_path)])
            if result.returncode != 0:
                die(f"download failed (curl exit {result.returncode})")

        install_path = make_archive_path(stem, ext)
        # mkstemp created install_path empty; replace it with the download.
        shutil.move(str(incoming_path), install_path)
        incoming_path = None  # don't try to rm in the finally
    finally:
        if incoming_path is not None and incoming_path.exists():
            try:
                incoming_path.unlink()
            except OSError:
                pass

    activate(install_path)
    print(f"Set wallpaper to {install_path}")
    return 0


def cmd_use(args: argparse.Namespace) -> int:
    ensure_dirs()
    archive_path: Path
    if args.archive_file is None:
        picked = pick_with_fzf()
        if picked is None:
            return 0  # user aborted
        archive_path = picked
    else:
        candidate = Path(args.archive_file)
        if candidate.is_file():
            archive_path = candidate
        elif (ARCHIVE_DIR / args.archive_file).is_file():
            archive_path = ARCHIVE_DIR / args.archive_file
        else:
            die(f"archive file not found: {args.archive_file}")

    activate(archive_path)
    print(f"Using wallpaper {archive_path}")
    return 0


def cmd_current(_args: argparse.Namespace) -> int:
    path = _resolve_current()
    if path is None:
        return 1
    print(path)
    return 0


def _resolve_current() -> Path | None:
    """Return the active wallpaper's resolved path, or None if not set."""
    for candidate in (CURRENT_LINK, FALLBACK_CURRENT):
        if candidate.is_file():
            try:
                return candidate.resolve(strict=True)
            except OSError:
                return candidate
    return None


def cmd_status(_args: argparse.Namespace) -> int:
    """Print JSON describing the active wallpaper plus lock-cache state.

    Pure cache read — doesn't render on demand. Returns exit 1 with
    `null` when no wallpaper is set; lock-screen treats that as the
    'fall back to solid color' signal.
    """
    path = _resolve_current()
    if path is None:
        print("null")
        return 1

    lock_image: str | None = None
    accent: str | None = None
    paths = _cache_paths(path)
    if paths is not None:
        img_path, color_path = paths
        if img_path.is_file() and img_path.stat().st_size > 0:
            lock_image = str(img_path)
            _touch(img_path)
        if color_path.is_file() and color_path.stat().st_size > 0:
            try:
                cached = color_path.read_text().strip()
                if re.fullmatch(r"[0-9a-fA-F]{6}", cached):
                    accent = cached
                    _touch(color_path)
            except OSError:
                pass

    print(json.dumps({
        "path": str(path),
        "lock_image": lock_image,
        "accent": accent,
    }))
    return 0


def cmd_rebuild_cache(_args: argparse.Namespace) -> int:
    """Force-rebuild the lock image + accent for the current wallpaper."""
    path = _resolve_current()
    if path is None:
        die("no current wallpaper to rebuild cache for")
    image, accent = build_lock_cache(path, force=True)
    if image is None and accent is None:
        die("rebuild failed (is `magick` on PATH?)")
    print(json.dumps({
        "path": str(path),
        "lock_image": str(image) if image else None,
        "accent": accent,
    }))
    return 0


def cmd_restart(_args: argparse.Namespace) -> int:
    restart_swaybg()
    return 0


def cmd_preview(args: argparse.Namespace) -> int:
    candidate = Path(args.archive_file)
    if not candidate.is_file():
        candidate = ARCHIVE_DIR / args.archive_file
        if not candidate.is_file():
            return 0

    if shutil.which("chafa") is not None:
        cols = os.environ.get("FZF_PREVIEW_COLUMNS", "80")
        lines = os.environ.get("FZF_PREVIEW_LINES", "24")
        result = subprocess.run(
            [
                "chafa",
                "--animate=off",
                f"--size={cols}x{lines}",
                str(candidate),
            ]
        )
        if result.returncode == 0:
            return 0

    print(candidate)
    return 0


# ----------------------------------------------------------------------
# fzf picker
# ----------------------------------------------------------------------


def _list_archive_basenames() -> list[str]:
    """Sorted (newest first) basenames of every archive entry."""
    if not ARCHIVE_DIR.is_dir():
        return []
    return sorted(
        (p.name for p in ARCHIVE_DIR.iterdir() if p.is_file()),
        reverse=True,
    )


def pick_with_fzf() -> Path | None:
    if shutil.which("fzf") is None:
        die("fzf is required for interactive selection")

    entries = _list_archive_basenames()
    if not entries:
        return None

    self_path = Path(__file__).resolve()
    fzf = subprocess.run(
        [
            "fzf",
            "--prompt=wallpaper> ",
            "--border-label= wallpapers ",
            "--header=enter: use   ctrl-shift-d: delete   esc: cancel",
            "--no-multi",
            "--preview-window=up:60%",
            "--preview",
            f"{self_path} preview {{}} 2>/dev/null",
            # Ctrl-Shift-D triggers immediate delete via _delete-archive,
            # then reload re-emits the archive listing. The shortcut is
            # deliberate enough that no extra confirmation is needed; the
            # entry under cursor is shown in the picker. _delete-archive
            # refuses to delete the currently-active wallpaper (would
            # leave a dangling `current` symlink) and opportunistically
            # cleans the lock-screen cache for the deleted entry.
            "--bind",
            (
                f"ctrl-D:execute-silent({self_path} _delete-archive {{}})"
                f"+reload({self_path} _list-archive)"
            ),
        ],
        input="\n".join(entries),
        text=True,
        capture_output=True,
    )
    if fzf.returncode != 0:
        return None
    choice = fzf.stdout.strip()
    if not choice:
        return None
    return ARCHIVE_DIR / choice


# ----------------------------------------------------------------------
# Internal subcommands used by the fzf picker (not part of the public CLI)
# ----------------------------------------------------------------------


def cmd__list_archive(_args: argparse.Namespace) -> int:
    """Print archive entries (basenames, newest first), one per line.

    Used as both the initial input and the reload source for the fzf
    picker. Lives as a subcommand rather than inline shell so the
    picker stays declarative.
    """
    for name in _list_archive_basenames():
        print(name)
    return 0


def cmd__delete_archive(args: argparse.Namespace) -> int:
    """Delete an archive entry + opportunistically nuke its lock cache.

    Refuses to delete the currently-active wallpaper (would leave a
    dangling `current` symlink). Errors are printed to stderr but the
    return code is intentionally always 0 — fzf's reload path doesn't
    care, and a non-zero exit would surface as a confusing fzf error
    line. The user just sees the entry vanish (or not, if it's the
    active one).
    """
    name = args.basename
    target = ARCHIVE_DIR / name
    if not target.is_file():
        print(f"wallpaper: not in archive: {name}", file=sys.stderr)
        return 0

    active = _resolve_current()
    if active is not None and active.resolve() == target.resolve():
        print(
            f"wallpaper: refusing to delete currently-active wallpaper "
            f"({name}); switch to another first",
            file=sys.stderr,
        )
        return 0

    # Find any cache entries derived from this wallpaper. The cache key
    # folds in the wallpaper's mtime, so we look up before unlinking.
    paths = _cache_paths(target)

    try:
        target.unlink()
    except OSError as exc:
        print(f"wallpaper: failed to delete {name}: {exc}", file=sys.stderr)
        return 0

    if paths is not None:
        for cache_file in paths:
            try:
                cache_file.unlink(missing_ok=True)
            except OSError:
                pass
    return 0


# ----------------------------------------------------------------------
# CLI
# ----------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="wallpaper",
        description="Manage swaybg wallpapers under ~/.local/share/wallpapers/.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_set = sub.add_parser("set", help="download or copy a wallpaper, then activate")
    p_set.add_argument("source", help="URL or local file path")
    p_set.set_defaults(func=cmd_set)

    p_use = sub.add_parser("use", help="activate an existing archive entry (fzf if no arg)")
    p_use.add_argument("archive_file", nargs="?", default=None,
                       help="archive entry (basename or path); fzf picker if omitted")
    p_use.set_defaults(func=cmd_use)

    p_current = sub.add_parser("current", help="print the active wallpaper path")
    p_current.set_defaults(func=cmd_current)

    p_status = sub.add_parser(
        "status",
        help="print JSON {path, lock_image, accent} for the active wallpaper",
    )
    p_status.set_defaults(func=cmd_status)

    p_rebuild = sub.add_parser(
        "rebuild-cache",
        help="force-rebuild the lock image + accent for the current wallpaper",
    )
    p_rebuild.set_defaults(func=cmd_rebuild_cache)

    p_restart = sub.add_parser("restart", help="restart swaybg.service")
    p_restart.set_defaults(func=cmd_restart)

    p_preview = sub.add_parser("preview", help="chafa render for fzf preview pane")
    p_preview.add_argument("archive_file")
    p_preview.set_defaults(func=cmd_preview)

    # Internal subcommands used by the fzf picker via --bind. The
    # leading underscore + the lack of `help=` keeps them out of the
    # per-line descriptions in --help; they still appear in the
    # {a,b,c,...} choice list (argparse limitation), which is fine for
    # signalling "internal but technically callable".
    p_list = sub.add_parser("_list-archive")
    p_list.set_defaults(func=cmd__list_archive)

    p_del = sub.add_parser("_delete-archive")
    p_del.add_argument("basename")
    p_del.set_defaults(func=cmd__delete_archive)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
