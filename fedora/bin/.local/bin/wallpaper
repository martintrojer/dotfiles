#!/usr/bin/env python3
"""Manage sway wallpapers, lock-screen render cache, and fzf previews."""

from __future__ import annotations

import argparse
import contextlib
import hashlib
import json
import os
import shutil
import socket
import string
import subprocess
import sys
import tempfile
from datetime import datetime
from pathlib import Path
from typing import NoReturn
from urllib.parse import urlparse

# ----------------------------------------------------------------------
# Paths (single source of truth; no global-shadowing footguns)
# ----------------------------------------------------------------------

XDG_DATA_HOME = Path(
    os.environ.get("XDG_DATA_HOME") or Path.home() / ".local" / "share"
)
XDG_CACHE_HOME = Path(os.environ.get("XDG_CACHE_HOME") or Path.home() / ".cache")

TARGET_DIR = XDG_DATA_HOME / "wallpapers"
ARCHIVE_DIR = TARGET_DIR / "archive"
CURRENT_LINK = TARGET_DIR / "current"
CACHE_DIR = XDG_CACHE_HOME / "wallpaper"


# ----------------------------------------------------------------------
# Lock-image render recipe
# ----------------------------------------------------------------------

BLUR_SIGMA = 8.0
# ImageMagick `-font` is happiest with a concrete font file in this
# environment: the mise-built ImageMagick has FreeType support, but
# `magick -list font` is empty and family/pattern lookups fail even
# though fontconfig can see the font. Try concrete bundled/user/system
# font paths first, then fall back to names for installs where
# ImageMagick's font registry works.
FONT_CANDIDATES = (
    XDG_DATA_HOME / "fonts" / "SF-Compact-Text-Bold.otf",
    XDG_DATA_HOME / "fonts" / "JetBrainsMono" / "JetBrainsMono-Bold.ttf",
    XDG_DATA_HOME / "fonts" / "JetBrainsMonoNerd" / "JetBrainsMonoNerdFont-Bold.ttf",
    Path("/usr/share/fonts/google-noto-sans-vf/NotoSans[wght].ttf"),
    Path("/usr/share/fonts/dejavu-sans-fonts/DejaVuSans-Bold.ttf"),
    "SF-Compact-Text-Bold",
    "JetBrainsMono-NF-Bold",
    "DejaVu-Sans-Bold",
)
# Banner geometry as fractions of wallpaper height (back-derived from
# the prior fixed 1080p values: 42/30 pt, 152/100 px from south).
LINE1_PT_FRAC, LINE2_PT_FRAC = 0.039, 0.028
LINE1_Y_FRAC, LINE2_Y_FRAC = 0.141, 0.093
SHADOW_OFFSET_FRAC = 0.0019
# Bump when changing anything that affects a cached artifact (font,
# pointsizes, blur recipe, banner geometry, sixel encoding). The cache
# key folds this in, so changes invalidate every <key>.* entry in one
# go — lock PNG and per-pane-size sixels alike.
RENDER_VERSION = 17
# Lock images are display artifacts, not archival copies. Downscale very
# large wallpapers before blur/banner rendering so cache rebuilds stay
# fast and do not hit subprocess timeouts on 5K/8K sources.
LOCK_MAX_WIDTH = 2560
LOCK_MAX_HEIGHT = 1440
LOCK_RENDER_TIMEOUT = 20
# Catppuccin Mocha base — sixel preview canvas fill. The fixed canvas
# matters because fzf/foot don't reliably clear old sixel pixels when
# consecutive previews have different intrinsic sizes.
PREVIEW_BACKGROUND_COLOR = "#1e1e2e"
# Keep sixel payloads well below the size where foot/fzf starts to
# silently fail on large/high-detail wallpapers. This was observed on
# the largest archive entries at ~1 MiB: direct `cat *.sixel-*` in foot
# produced no image even though the sixel bytes were valid. `+dither`
# avoids noisy diffusion patterns that compress poorly in sixel output.
PREVIEW_COLORS = 48
# Catppuccin Mocha 'text' — banner color.
# THEME BEGIN: wallpaper-fallback-color
BANNER_TEXT_COLOR = "cdd6f4"
# THEME END: wallpaper-fallback-color


# ----------------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------------

_STEM_KEEP = set(string.ascii_letters + string.digits + "._-")


def die(msg: str, code: int = 1) -> NoReturn:
    print(f"wallpaper: {msg}", file=sys.stderr)
    raise SystemExit(code)


def sanitize_stem(name: str) -> tuple[str, str]:
    """Split a basename into (sanitized_stem, ext_with_dot).

    Mirrors the bash version: keep ASCII letters, digits, dot, underscore,
    hyphen; replace everything else with '-' and squash repeats; strip
    leading/trailing '-'; fall back to 'wallpaper' if the result is empty.
    A leading dot makes the whole thing a stem with no extension.
    """
    if "." in name and not name.startswith("."):
        stem, _, ext = name.rpartition(".")
        ext = "." + ext
    else:
        stem, ext = name, ""

    out: list[str] = []
    last_dash = False
    for ch in stem:
        if ch in _STEM_KEEP:
            out.append(ch)
            last_dash = False
        elif not last_dash:
            out.append("-")
            last_dash = True
    sanitized = "".join(out).strip("-") or "wallpaper"
    return sanitized, ext


def basename_from_url_or_path(src: str) -> str:
    """Strip URL query string before taking basename, leave file paths alone."""
    parsed = urlparse(src)
    if parsed.scheme in ("http", "https", "ftp", "file"):
        return Path(parsed.path).name or "wallpaper"
    return Path(src).name


def make_archive_path(stem: str, ext: str, timestamp: str | None = None) -> Path:
    """Allocate a unique filename under ARCHIVE_DIR using mkstemp.

    Format: <YYYYMMDD-HHMMSS>-<stem>.<6 random chars><ext>
    Matches the bash mktemp template format. mkstemp guarantees uniqueness
    even under racing callers and creates the file with mode 0600.
    """
    ts = timestamp or datetime.now().strftime("%Y%m%d-%H%M%S")
    fd, path = tempfile.mkstemp(
        prefix=f"{ts}-{stem}.",
        suffix=ext,
        dir=str(ARCHIVE_DIR),
    )
    os.close(fd)
    return Path(path)


def ensure_dirs() -> None:
    ARCHIVE_DIR.mkdir(parents=True, exist_ok=True)


def require_systemctl() -> None:
    if shutil.which("systemctl") is None:
        die("systemctl is unavailable")


def restart_swaybg() -> None:
    require_systemctl()
    if (
        subprocess.run(["systemctl", "--user", "restart", "swaybg.service"]).returncode
        != 0
    ):
        die("failed to restart swaybg.service")


# ----------------------------------------------------------------------
# Cache: lock image + per-pane-size sixel previews
#
# Files live at $XDG_CACHE_HOME/wallpaper/<sha>.{png,sixel-WxH}.
# Key is wallpaper path + mtime + RENDER_VERSION; bumping the version
# (or editing the source wallpaper) invalidates the entry automatically.
# Entries are removed when the source archive entry is deleted; there
# is no time-based pruning, so a wallpaper kept around for years keeps
# its warm lock-screen cache for years.
#
# Lock-screen reads the PNG via `wallpaper status`. Wallpaper set/use
# pre-render it so the next lock is instant. Sixels are rendered on
# demand by `wallpaper preview` (used by the fzf picker) and cached per
# (cols x lines) pane size on first paint.
# ----------------------------------------------------------------------


def _cache_key(wallpaper: Path) -> str | None:
    """Stable key derived from canonical path + mtime + RENDER_VERSION."""
    try:
        source = wallpaper.resolve(strict=True)
        mtime = source.stat().st_mtime_ns
    except OSError:
        return None
    raw = f"{source}\0{mtime}\0v={RENDER_VERSION}".encode()
    return hashlib.sha1(raw).hexdigest()[:16]


def _cache_path(wallpaper: Path) -> Path | None:
    key = _cache_key(wallpaper)
    if key is None:
        return None
    return CACHE_DIR / f"{key}.png"


def _sixel_cache_path(wallpaper: Path, cols: int, lines: int) -> Path | None:
    """Cache path for a (wallpaper, cols x lines) sixel render.

    Shares the wallpaper's `_cache_key` with the lock PNG so
    `cmd__delete_archive` can glob `<key>.*` and clean every artifact
    derived from one archive entry in a single pass. Returns None if
    the wallpaper's mtime can't be stat'd.
    """
    key = _cache_key(wallpaper)
    if key is None:
        return None
    return CACHE_DIR / f"{key}.sixel-{cols}x{lines}"


def _file_identity(path: Path) -> tuple[int, int, int, int] | None:
    """Return the source identity that must remain stable during render.

    Preview renders are intentionally asynchronous under fzf: moving the
    cursor can kill/restart preview commands while ImageMagick is still
    doing work. Cache writes therefore re-check this identity after the
    render and only publish bytes if the path still names the same file
    content we keyed at the start. That prevents a late render from
    populating a stale/wrong `.sixel-*` cache path after an archive entry
    is replaced, deleted, or otherwise races with the preview process.
    """
    try:
        st = path.stat()
    except OSError:
        return None
    return (st.st_dev, st.st_ino, st.st_size, st.st_mtime_ns)


def _atomic_write(path: Path, data: bytes) -> None:
    """Write bytes via temp + rename so concurrent preview processes
    don't see torn files. Best-effort: failures are swallowed since a
    missing cache just means the next preview re-renders.
    """
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        fd, tmp_str = tempfile.mkstemp(
            dir=str(CACHE_DIR), prefix=".sixel.", suffix=".tmp"
        )
    except OSError:
        return
    tmp_path = Path(tmp_str)
    try:
        with os.fdopen(fd, "wb") as fp:
            fp.write(data)
        os.replace(tmp_path, path)
    except OSError:
        with contextlib.suppress(OSError):
            tmp_path.unlink()


def _font_args(font: str | Path) -> list[str]:
    return ["-font", str(font)]


def _available_fonts() -> list[str | Path]:
    """Return ImageMagick font candidates that are plausible here.

    Path candidates must exist. Name candidates are kept as a final
    fallback for systems where ImageMagick's own font registry works.
    """
    fonts: list[str | Path] = []
    for candidate in FONT_CANDIDATES:
        if isinstance(candidate, Path):
            if candidate.is_file():
                fonts.append(candidate)
        else:
            fonts.append(candidate)
    return fonts


def _is_font_error(stderr: bytes) -> bool:
    text = stderr.decode(errors="ignore").lower()
    return "unable to read font" in text or "renderfreetype" in text


def _summarize_stderr(stderr: bytes) -> str:
    text = stderr.decode(errors="ignore").strip()
    if not text:
        return "no error output"
    return " ".join(text.split())[:240]


def _lock_render_tmp(dst: Path) -> Path | None:
    try:
        dst.parent.mkdir(parents=True, exist_ok=True)
        fd, tmp_str = tempfile.mkstemp(
            dir=str(dst.parent), prefix=f".{dst.name}.", suffix=".tmp.png"
        )
        os.close(fd)
    except OSError:
        return None
    return Path(tmp_str)


def _publish_lock_render(tmp_path: Path, dst: Path) -> str | None:
    if not tmp_path.is_file():
        return "renderer produced no output file"
    if tmp_path.stat().st_size <= 0:
        return "renderer produced an empty output file"
    try:
        os.replace(tmp_path, dst)
    except OSError as exc:
        return f"failed to publish cache image: {exc}"
    return None


def _build_lock_image(src: Path, dst: Path) -> tuple[bool, str | None]:
    """Render blurred + banner-stamped wallpaper to dst."""
    if not shutil.which("magick"):
        return False, "magick not found on PATH"
    # Pull dimensions to scale geometry; bail rather than render illegibly.
    try:
        dim = subprocess.run(
            ["magick", "identify", "-format", "%w %h", str(src)],
            capture_output=True,
            text=True,
            timeout=10,
            check=False,
        )
        if dim.returncode != 0:
            return (
                False,
                f"failed to identify source image: {_summarize_stderr(dim.stderr.encode())}",
            )
        width, height = (int(part) for part in dim.stdout.split())
    except subprocess.TimeoutExpired:
        return False, "timed out identifying source image after 10s"
    except (OSError, subprocess.SubprocessError, ValueError) as exc:
        return False, f"failed to identify source image: {exc}"
    if width <= 0 or height <= 0:
        return False, f"invalid source dimensions: {width}x{height}"

    scale = min(1.0, LOCK_MAX_WIDTH / width, LOCK_MAX_HEIGHT / height)
    render_height = max(1, round(height * scale))

    line1 = "LOCKED"
    line2 = f"{os.environ.get('USER', 'user')}@{socket.gethostname().split('.')[0]}"
    # y-offsets are from the bottom (gravity south); larger y = higher up.
    line1_y = round(render_height * LINE1_Y_FRAC)
    line2_y = round(render_height * LINE2_Y_FRAC)
    line1_pt = str(round(render_height * LINE1_PT_FRAC))
    line2_pt = str(round(render_height * LINE2_PT_FRAC))
    shadow_off = max(1, round(render_height * SHADOW_OFFSET_FRAC))
    fill = f"#{BANNER_TEXT_COLOR}ff"
    shadow = "#00000099"
    base_cmd: list[str] = [
        "magick",
        str(src),
        "-sample",
        f"{LOCK_MAX_WIDTH}x{LOCK_MAX_HEIGHT}>",
        "-blur",
        f"0x{BLUR_SIGMA}",
    ]
    base_cmd += ["-gravity", "south"]
    annotate_args: list[str] = []
    for text, y, pt in ((line1, line1_y, line1_pt), (line2, line2_y, line2_pt)):
        annotate_args += [
            "-pointsize",
            pt,
            "-fill",
            shadow,
            "-annotate",
            f"+{shadow_off}+{y - shadow_off}",
            text,
            "-fill",
            fill,
            "-annotate",
            f"+0+{y}",
            text,
        ]

    saw_font_error = False
    for font in _available_fonts():
        tmp_path = _lock_render_tmp(dst)
        if tmp_path is None:
            return False, f"failed to create temporary render file under {dst.parent}"
        cmd = [
            *base_cmd,
            *_font_args(font),
            *annotate_args,
            "-alpha",
            "remove",
            "-strip",
            "-define",
            "png:compression-level=1",
            str(tmp_path),
        ]
        try:
            res = subprocess.run(
                cmd,
                capture_output=True,
                timeout=LOCK_RENDER_TIMEOUT,
                check=False,
            )
        except subprocess.TimeoutExpired:
            with contextlib.suppress(OSError):
                tmp_path.unlink()
            return False, f"timed out rendering lock image after {LOCK_RENDER_TIMEOUT}s"
        except (OSError, subprocess.SubprocessError) as exc:
            with contextlib.suppress(OSError):
                tmp_path.unlink()
            return False, f"failed to run ImageMagick: {exc}"
        publish_error = (
            _publish_lock_render(tmp_path, dst) if res.returncode == 0 else None
        )
        if publish_error is None and res.returncode == 0:
            return True, None
        with contextlib.suppress(OSError):
            tmp_path.unlink()
        if _is_font_error(res.stderr):
            saw_font_error = True
            continue
        if publish_error is not None:
            return False, publish_error
        return (
            False,
            f"ImageMagick exited {res.returncode}: {_summarize_stderr(res.stderr)}",
        )

    # Last-resort graceful fallback: produce the blurred image without
    # banner text. Lock-screen still gets the important part (blurred
    # wallpaper) even on hosts where no ImageMagick-readable font can be
    # found. Only use this path for font failures; other ImageMagick
    # errors may mean the source image itself is unreadable.
    if saw_font_error:
        tmp_path = _lock_render_tmp(dst)
        if tmp_path is None:
            return False, f"failed to create temporary render file under {dst.parent}"
        try:
            res = subprocess.run(
                [
                    "magick",
                    str(src),
                    "-sample",
                    f"{LOCK_MAX_WIDTH}x{LOCK_MAX_HEIGHT}>",
                    "-blur",
                    f"0x{BLUR_SIGMA}",
                    "-alpha",
                    "remove",
                    "-strip",
                    "-define",
                    "png:compression-level=1",
                    str(tmp_path),
                ],
                capture_output=True,
                timeout=LOCK_RENDER_TIMEOUT,
                check=False,
            )
        except subprocess.TimeoutExpired:
            with contextlib.suppress(OSError):
                tmp_path.unlink()
            return False, f"timed out rendering lock image after {LOCK_RENDER_TIMEOUT}s"
        except (OSError, subprocess.SubprocessError) as exc:
            with contextlib.suppress(OSError):
                tmp_path.unlink()
            return False, f"failed to run ImageMagick fallback: {exc}"
        publish_error = (
            _publish_lock_render(tmp_path, dst) if res.returncode == 0 else None
        )
        if publish_error is None and res.returncode == 0:
            return True, None
        with contextlib.suppress(OSError):
            tmp_path.unlink()
        if publish_error is not None:
            return False, publish_error
        return (
            False,
            f"ImageMagick fallback exited {res.returncode}: {_summarize_stderr(res.stderr)}",
        )

    return False, "all configured fonts failed"


def build_lock_cache(
    wallpaper: Path, *, force: bool = False, verbose: bool = False
) -> tuple[Path | None, str | None]:
    """Render the lock image for `wallpaper` if missing or forced."""
    img_path = _cache_path(wallpaper)
    if img_path is None:
        return None, "wallpaper path could not be stat'd"
    CACHE_DIR.mkdir(parents=True, exist_ok=True)

    cache_hit = not force and img_path.is_file() and img_path.stat().st_size > 0
    if verbose and not cache_hit:
        print("Generating lock-screen image... ", end="", flush=True)

    if force:
        img_path.unlink(missing_ok=True)

    image: Path | None = None
    error: str | None = None
    if img_path.is_file() and img_path.stat().st_size > 0:
        image = img_path
    else:
        ok, error = _build_lock_image(wallpaper, img_path)
        if ok:
            image = img_path

    if verbose and not cache_hit:
        print("done" if image else f"failed: {error or 'unknown error'}", flush=True)

    return image, error


# ----------------------------------------------------------------------
# Activate (shared by `set` and `use`)
# ----------------------------------------------------------------------


def archive_existing_current() -> None:
    """Snapshot the current wallpaper into the archive, unless it already
    lives there.

    Same dance as the bash version: if `current` is a symlink, copy the
    target into the archive (preserving the source for whoever else might
    point at it). If `current` is a plain file, move it. If `current` is
    already inside ARCHIVE_DIR, no-op.
    """
    if not CURRENT_LINK.exists() and not CURRENT_LINK.is_symlink():
        return

    try:
        resolved = CURRENT_LINK.resolve(strict=True)
    except (OSError, RuntimeError):
        return

    if not resolved.is_file():
        return

    try:
        resolved.relative_to(ARCHIVE_DIR.resolve())
        return  # already in archive; nothing to snapshot
    except ValueError:
        pass

    stem, ext = sanitize_stem(resolved.name)
    archived = make_archive_path(stem, ext)
    if CURRENT_LINK.is_symlink():
        shutil.copy2(resolved, archived)
    else:
        shutil.move(str(CURRENT_LINK), archived)


def activate(archive_path: Path) -> None:
    if not archive_path.is_file():
        die(f"archive file not found: {archive_path}")

    archive_existing_current()
    if CURRENT_LINK.exists() or CURRENT_LINK.is_symlink():
        CURRENT_LINK.unlink()
    CURRENT_LINK.symlink_to(archive_path)
    restart_swaybg()
    # Pre-render the lock image so the next lock is instant. Best-effort
    # — a render failure here doesn't fail the activate; lock-screen
    # falls back to a solid-color lock when the cache is missing.
    build_lock_cache(archive_path, verbose=True)


# ----------------------------------------------------------------------
# Subcommands
# ----------------------------------------------------------------------


def cmd_set(args: argparse.Namespace) -> int:
    src: str = args.source
    ensure_dirs()

    source_name = basename_from_url_or_path(src)
    stem, ext = sanitize_stem(source_name)

    incoming_fd, incoming_path_str = tempfile.mkstemp(
        prefix=".incoming.", dir=str(ARCHIVE_DIR)
    )
    os.close(incoming_fd)
    incoming_path = Path(incoming_path_str)

    try:
        if Path(src).is_file():
            shutil.copy2(src, incoming_path)
        else:
            if shutil.which("curl") is None:
                die("curl is required for URL downloads")
            result = subprocess.run(["curl", "-fL", src, "-o", str(incoming_path)])
            if result.returncode != 0:
                die(f"download failed (curl exit {result.returncode})")

        install_path = make_archive_path(stem, ext)
        # mkstemp created install_path empty; replace it with the download.
        shutil.move(str(incoming_path), install_path)
        incoming_path = None  # don't try to rm in the finally
    finally:
        if incoming_path is not None and incoming_path.exists():
            with contextlib.suppress(OSError):
                incoming_path.unlink()

    activate(install_path)
    print(f"Set wallpaper to {install_path}")
    return 0


def cmd_use(args: argparse.Namespace) -> int:
    ensure_dirs()
    archive_path: Path
    if args.archive_file is None:
        picked = pick_with_fzf()
        if picked is None:
            return 0  # user aborted
        archive_path = picked
    else:
        candidate = Path(args.archive_file)
        if candidate.is_file():
            archive_path = candidate
        elif (ARCHIVE_DIR / args.archive_file).is_file():
            archive_path = ARCHIVE_DIR / args.archive_file
        else:
            die(f"archive file not found: {args.archive_file}")

    activate(archive_path)
    print(f"Using wallpaper {archive_path}")
    return 0


def cmd_current(_args: argparse.Namespace) -> int:
    path = _resolve_current()
    if path is None:
        return 1
    print(path)
    return 0


def _resolve_current() -> Path | None:
    """Return the active wallpaper's resolved path, or None if not set."""
    if not CURRENT_LINK.is_file():
        return None
    try:
        return CURRENT_LINK.resolve(strict=True)
    except OSError:
        return CURRENT_LINK


def cmd_status(_args: argparse.Namespace) -> int:
    """Print JSON describing the active wallpaper plus lock-cache state.

    Pure cache read — doesn't render on demand. Returns exit 1 with
    `null` when no wallpaper is set; lock-screen treats that as the
    'fall back to solid color' signal.
    """
    path = _resolve_current()
    if path is None:
        print("null")
        return 1

    lock_image: str | None = None
    img_path = _cache_path(path)
    if img_path is not None and img_path.is_file() and img_path.stat().st_size > 0:
        lock_image = str(img_path)

    print(
        json.dumps(
            {
                "path": str(path),
                "lock_image": lock_image,
            }
        )
    )
    return 0


def cmd_rebuild_cache(_args: argparse.Namespace) -> int:
    """Force-rebuild the lock image for the current wallpaper."""
    path = _resolve_current()
    if path is None:
        die("no current wallpaper to rebuild cache for")
    image, error = build_lock_cache(path, force=True)
    if image is None:
        die(f"lock image rebuild failed: {error or 'unknown error'}")
    print(
        json.dumps(
            {
                "path": str(path),
                "lock_image": str(image) if image else None,
            }
        )
    )
    return 0


def cmd_restart(_args: argparse.Namespace) -> int:
    restart_swaybg()
    return 0


def _env_positive_int(name: str, default: int) -> int:
    """Return a positive int from an env var, falling back on bad input."""
    try:
        value = int(os.environ.get(name, ""))
    except ValueError:
        return default
    return value if value > 0 else default


def cmd_preview(args: argparse.Namespace) -> int:
    candidate = Path(args.archive_file)
    if not candidate.is_file():
        candidate = ARCHIVE_DIR / args.archive_file
        if not candidate.is_file():
            return 0

    # Sixel preview in foot (native support). Uses ImageMagick (`magick`)
    # which ships in the Sericea base, so no extra packages are required.
    # fzf's preview pane is sized in cells (cols x lines); rough cell
    # geometry of 8x16 px gets us close to the actual pixel area without
    # querying the terminal. Each preview is rendered onto a fixed-size
    # Catppuccin canvas before sixel encoding: foot/fzf don't reliably
    # clear old sixel pixels when the next preview is smaller, so a
    # same-size opaque canvas makes every render overwrite the previous
    # one. The `>` qualifier on -resize means "only shrink, never
    # enlarge" — small thumbnails stay sharp and are centered on the
    # canvas. The image is then quantized before sixel encoding so
    # very detailed wallpapers don't produce ~1 MiB sixel payloads; foot
    # can silently refuse to paint those even when `cat`ting the sixel
    # directly outside fzf.
    #
    # Cached per (wallpaper key, cols x lines): first preview pays the
    # ~200-400ms magick startup + decode + sixel encode cost, subsequent
    # cursor moves over the same entry at the same pane size are a
    # bytes-to-stdout pass. Cache entries share <key>.* with the lock
    # PNG and get cleaned together when the archive entry is
    # deleted.
    if shutil.which("magick") is not None:
        cols = _env_positive_int("FZF_PREVIEW_COLUMNS", 80)
        lines = _env_positive_int("FZF_PREVIEW_LINES", 24)
        source_identity = _file_identity(candidate)
        width = cols * 8
        height = lines * 16
        cache_path = _sixel_cache_path(candidate, cols, lines)

        # Always clear the preview pane immediately. This must happen
        # before a possible slow render too; otherwise selecting an
        # uncached/expensive wallpaper appears to "do nothing" until
        # ImageMagick finishes, and quick cursor movement can leave the
        # previous sixel visible long enough to look stuck.
        clear_preview = b"\033[2J\033[H"
        sys.stdout.buffer.write(clear_preview)
        sys.stdout.buffer.flush()

        if (
            cache_path is not None
            and source_identity is not None
            and cache_path.is_file()
            and cache_path.stat().st_size > 0
        ):
            try:
                sys.stdout.buffer.write(cache_path.read_bytes())
                sys.stdout.buffer.flush()
                return 0
            except OSError:
                pass  # fall through to re-render

        result = subprocess.run(
            [
                "magick",
                str(candidate),
                "-resize",
                f"{width}x{height}>",
                "-background",
                PREVIEW_BACKGROUND_COLOR,
                "-gravity",
                "center",
                "-extent",
                f"{width}x{height}",
                "+dither",
                "-colors",
                str(PREVIEW_COLORS),
                "sixel:-",
            ],
            capture_output=True,
        )
        if result.returncode == 0 and result.stdout:
            if (
                cache_path is not None
                and source_identity is not None
                and _file_identity(candidate) == source_identity
            ):
                _atomic_write(cache_path, result.stdout)
            sys.stdout.buffer.write(result.stdout)
            sys.stdout.buffer.flush()
            return 0

    print(candidate)
    return 0


# ----------------------------------------------------------------------
# fzf picker
# ----------------------------------------------------------------------


def _list_archive_basenames() -> list[str]:
    """Sorted (newest first) basenames of every archive entry."""
    if not ARCHIVE_DIR.is_dir():
        return []
    return sorted(
        (p.name for p in ARCHIVE_DIR.iterdir() if p.is_file()),
        reverse=True,
    )


def pick_with_fzf() -> Path | None:
    if shutil.which("fzf") is None:
        die("fzf is required for interactive selection")

    entries = _list_archive_basenames()
    if not entries:
        return None

    self_path = Path(__file__).resolve()
    fzf = subprocess.run(
        [
            "fzf",
            "--prompt=wallpaper> ",
            "--border-label= wallpapers ",
            "--header=enter: use   ctrl-shift-d: delete   esc: cancel",
            "--no-multi",
            "--preview-window=up:60%",
            "--preview",
            f"{self_path} preview {{}} 2>/dev/null",
            # Ctrl-Shift-D triggers immediate delete via _delete-archive,
            # then reload re-emits the archive listing. The shortcut is
            # deliberate enough that no extra confirmation is needed; the
            # entry under cursor is shown in the picker. _delete-archive
            # refuses to delete the currently-active wallpaper (would
            # leave a dangling `current` symlink) and opportunistically
            # cleans the lock-screen cache for the deleted entry.
            "--bind",
            (
                f"ctrl-D:execute-silent({self_path} _delete-archive {{}})"
                f"+reload({self_path} _list-archive)"
            ),
        ],
        input="\n".join(entries),
        text=True,
        capture_output=True,
    )
    if fzf.returncode != 0:
        return None
    choice = fzf.stdout.strip()
    if not choice:
        return None
    return ARCHIVE_DIR / choice


# ----------------------------------------------------------------------
# Internal subcommands used by the fzf picker (not part of the public CLI)
# ----------------------------------------------------------------------


def cmd__list_archive(_args: argparse.Namespace) -> int:
    """Print archive entries (basenames, newest first), one per line.

    Used as both the initial input and the reload source for the fzf
    picker. Lives as a subcommand rather than inline shell so the
    picker stays declarative.
    """
    for name in _list_archive_basenames():
        print(name)
    return 0


def cmd__delete_archive(args: argparse.Namespace) -> int:
    """Delete an archive entry + opportunistically nuke its lock cache.

    Refuses to delete the currently-active wallpaper (would leave a
    dangling `current` symlink). Errors are printed to stderr but the
    return code is intentionally always 0 — fzf's reload path doesn't
    care, and a non-zero exit would surface as a confusing fzf error
    line. The user just sees the entry vanish (or not, if it's the
    active one).
    """
    name = args.basename
    target = ARCHIVE_DIR / name
    if not target.is_file():
        print(f"wallpaper: not in archive: {name}", file=sys.stderr)
        return 0

    active = _resolve_current()
    if active is not None and active.resolve() == target.resolve():
        print(
            f"wallpaper: refusing to delete currently-active wallpaper "
            f"({name}); switch to another first",
            file=sys.stderr,
        )
        return 0

    # Compute the cache key before unlinking — once the file is gone we
    # can't stat its mtime. Then glob <key>.* under CACHE_DIR to scoop
    # up the lock PNG and every per-pane-size sixel in
    # one pass.
    key = _cache_key(target)

    try:
        target.unlink()
    except OSError as exc:
        print(f"wallpaper: failed to delete {name}: {exc}", file=sys.stderr)
        return 0

    if key is not None:
        for cache_file in CACHE_DIR.glob(f"{key}.*"):
            with contextlib.suppress(OSError):
                cache_file.unlink()
    return 0


# ----------------------------------------------------------------------
# CLI
# ----------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="wallpaper",
        description="Manage swaybg wallpapers under ~/.local/share/wallpapers/.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_set = sub.add_parser("set", help="download or copy a wallpaper, then activate")
    p_set.add_argument("source", help="URL or local file path")
    p_set.set_defaults(func=cmd_set)

    p_use = sub.add_parser(
        "use", help="activate an existing archive entry (fzf if no arg)"
    )
    p_use.add_argument(
        "archive_file",
        nargs="?",
        default=None,
        help="archive entry (basename or path); fzf picker if omitted",
    )
    p_use.set_defaults(func=cmd_use)

    p_current = sub.add_parser("current", help="print the active wallpaper path")
    p_current.set_defaults(func=cmd_current)

    p_status = sub.add_parser(
        "status",
        help="print JSON {path, lock_image} for the active wallpaper",
    )
    p_status.set_defaults(func=cmd_status)

    p_rebuild = sub.add_parser(
        "rebuild-cache",
        help="force-rebuild the lock image for the current wallpaper",
    )
    p_rebuild.set_defaults(func=cmd_rebuild_cache)

    p_restart = sub.add_parser("restart", help="restart swaybg.service")
    p_restart.set_defaults(func=cmd_restart)

    p_preview = sub.add_parser("preview", help="sixel render for fzf preview pane")
    p_preview.add_argument("archive_file")
    p_preview.set_defaults(func=cmd_preview)

    # Internal subcommands used by the fzf picker via --bind. The
    # leading underscore + the lack of `help=` keeps them out of the
    # per-line descriptions in --help; they still appear in the
    # {a,b,c,...} choice list (argparse limitation), which is fine for
    # signalling "internal but technically callable".
    p_list = sub.add_parser("_list-archive")
    p_list.set_defaults(func=cmd__list_archive)

    p_del = sub.add_parser("_delete-archive")
    p_del.add_argument("basename")
    p_del.set_defaults(func=cmd__delete_archive)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
