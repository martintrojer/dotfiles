[Unit]
Description=Waybar Status Bar (Sway)
PartOf=sway-session.target
BindsTo=sway-session.target
After=sway-session.target

[Service]
Type=simple
ExecStart=/usr/bin/waybar --config %h/.config/waybar/config.jsonc --style %h/.config/waybar/style.css
Restart=always
RestartSec=1

[Install]
WantedBy=sway-session.target
