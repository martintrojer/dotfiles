{
	"model": "cli-only",
	"models": {
		"cli-only": {
			"mode": "auto",
			"rules": [
				{
					"candidates": ["cli/codex/gpt-5.4-mini", "cli/opencode/opencode/big-pickle", "cli/claude"]
				}
			]
		}
	},
	"cli": {
		"enabled": ["codex", "opencode", "claude"],
		"autoFallback": {
			"enabled": true,
			"onlyWhenNoApiKeys": true,
			"order": ["codex", "opencode", "claude"]
		},
		"codex": {
			"model": "gpt-5.4-mini"
		},
		"opencode": {
			"model": "opencode/big-pickle"
		}
	},
	"output": {
		"language": "auto",
		"length": "long"
	}
}
