# Catppuccin-flavoured Sway config.

set $mod Mod4
# Connects to sway-foot-server.service (see fedora/systemd/). Falling back
# to plain `foot` here would defeat the point of the server; if the daemon
# isn't running, fix the unit rather than papering over it.
set $term footclient
set $menu fuzzel --prompt 'Run ' --placeholder 'Search apps...'
set $browser sh -lc "$HOME/.config/sway/scripts/open-browser"
set $lock ~/.config/sway/scripts/lock-screen
set $quit ~/.config/sway/scripts/session-quit

# THEME BEGIN: sway-palette
set $rosewater #f5e0dc
set $mauve #cba6f7
set $red #f38ba8
set $blue #89b4fa
set $lavender #b4befe
set $text #cdd6f4
set $subtext0 #a6adc8
set $surface2 #585b70
set $surface0 #313244
set $overlay0 #6c7086
set $base #1e1e2e
set $mantle #181825
# THEME END: sway-palette

font pango:JetBrains Mono Nerd Font Bold 10

input * {
    xkb_layout us
    xkb_options caps:escape
}

input type:keyboard {
    xkb_numlock enabled
}

focus_follows_mouse yes
mouse_warping none
focus_wrapping no
# `workspace_auto_back_and_forth no`: pressing $mod+N while already on N is a
# no-op (idempotent). The toggle-to-last behaviour is reachable explicitly via
# $mod+g (`workspace back_and_forth`), which mirrors tmux prefix+g.
workspace_auto_back_and_forth no

# Hold $mod and drag with the mouse to move/resize floating windows.
# Left-click+drag = move; right-click+drag = resize.
# `normal` means tiled windows still receive clicks underneath the modifier.
floating_modifier $mod normal

# Outputs are intentionally left to kanshi.

default_border pixel 2
default_floating_border pixel 2
titlebar_padding 6 3
hide_edge_borders smart_no_gaps
gaps inner 4
gaps outer 0
smart_gaps off

# Keep the active tab filled even when focus is inside a split nested under it;
# the leaf window remains distinguishable by its blue child border.
client.focused          $surface2 $surface2 $lavender $surface2 $mauve
client.focused_inactive $surface2 $surface2 $lavender $surface2 $surface0
client.unfocused        $overlay0 $mantle  $overlay0 $mantle   $overlay0
client.urgent           $red      $red     $text     $red      $red
client.placeholder      $mantle   $mantle  $text     $mantle   $mantle
client.background       $base

for_window [title="^Picture in picture$"] floating enable, sticky enable, border pixel 2
for_window [title="^Picture-in-Picture$"] floating enable, sticky enable, border pixel 2
for_window [app_id="^pavucontrol$"] floating enable
for_window [app_id="^nm-connection-editor$"] floating enable
# Floating TUIs launched from waybar.
for_window [app_id="^wiremix-float$"] floating enable, resize set 720 480, move position center
for_window [app_id="^bluetui-float$"] floating enable, resize set 720 480, move position center
for_window [app_id="^nmtui-float$"] floating enable, resize set 720 480, move position center
# GNOME Calculator (flatpak): summon, type, dismiss.
for_window [app_id="^org\.gnome\.Calculator$"] floating enable, resize set 480 600, move position center
# Cider (Apple Music client) auto-stashes into the scratchpad on launch.
# Summon with $mod+n, hide with $mod+n. Never wastes a workspace slot.
for_window [app_id="^Cider$"] move scratchpad
# Prevent Sway from interfering with the game overlays
for_window [class="gamescope"] floating enable, border none, scaling disable

exec_always ~/.config/sway/scripts/session-start

# mod+F1 mirrors hammerspoon's Hyper+F1 help overlay on macOS.
bindsym $mod+F1 exec ~/.config/fuzzel/scripts/hotkeys

# mod+Return launches the terminal, mirroring hammerspoon's
# Hyper+Return on macOS so the verb is identical across both OSes.
bindsym $mod+Return exec $term
bindsym $mod+space exec $menu
bindsym $mod+b exec $browser
bindsym $mod+y exec sh -lc "$HOME/.config/sway/scripts/open-yazi"
bindsym $mod+m exec sh -lc "$HOME/.config/sway/scripts/open-cider"
bindsym $mod+Shift+m exec ~/.config/fuzzel/scripts/cider
bindsym $mod+i exec sh -lc "$HOME/.config/sway/scripts/open-vscode"

# Powermenu kept on Shift (destructive: lock/suspend/shutdown), the
# rest of the pickers promoted off Shift since they're frequent and
# non-destructive.
bindsym $mod+Shift+p exec ~/.config/fuzzel/scripts/powermenu
bindsym $mod+t exec ~/.config/fuzzel/scripts/toolboxes
bindsym $mod+s exec ~/.config/fuzzel/scripts/ssh
# mod+v: clipboard picker (mirrors tmux prefix+v).
bindsym $mod+v exec ~/.config/fuzzel/scripts/clipboard
bindsym $mod+e exec ~/.config/fuzzel/scripts/emoji
bindsym $mod+Tab exec ~/.config/fuzzel/scripts/windows
bindsym $mod+grave exec ~/.config/fuzzel/scripts/chrome-tabs
bindsym $mod+backslash exec ~/.config/fuzzel/scripts/calc

bindsym XF86AudioRaiseVolume exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioStop exec playerctl stop
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioNext exec playerctl next
bindsym XF86MonBrightnessUp exec brightnessctl s 10%+
bindsym XF86MonBrightnessDown exec brightnessctl s 10%-

bindsym $mod+Shift+q kill

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Page_Down workspace next
bindsym $mod+Page_Up workspace prev
# mod+g: toggle to last workspace (mirrors tmux prefix+g for last session).
bindsym $mod+g workspace back_and_forth
bindsym $mod+Ctrl+Page_Down move container to workspace next; workspace next
bindsym $mod+Ctrl+Page_Up move container to workspace prev; workspace prev
# Workspace-to-output is letter-based only (u=left, i=right); the
# Ctrl+Home/End and Shift+Page_Up/Down variants used to live here too
# but were never the form actually pressed.
bindsym $mod+Shift+u move workspace to output left
bindsym $mod+Shift+i move workspace to output right

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6

# Brackets for splits: [ = splitv (list, top/bottom), ] = splith (row).
# Sway's upstream idiom uses mod+b/v but those are browser/clipboard here.
bindsym $mod+bracketleft splitv
bindsym $mod+bracketright splith
bindsym $mod+period layout toggle tabbed split
# mod+r / mod+Shift+r mirror tmux prefix+r (cycle width) / prefix+R (reload).
bindsym $mod+r exec ~/.config/sway/scripts/preset-width
bindsym $mod+Shift+r reload
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
# mod+a: focus mode_toggle — the canonical sway verb for jumping
# between the tiled tree and the floating layer. Default key is
# mod+space, which is fuzzel here; mod+a is a single-key reach
# that doesn't conflict.
bindsym $mod+a focus mode_toggle
# Scratchpad: mod+Shift+n stashes, mod+n shows/cycles.
bindsym $mod+Shift+n move scratchpad
bindsym $mod+n scratchpad show
bindsym $mod+c focus parent
bindsym $mod+Ctrl+c focus child
# 50 px per press: noticeable on floats, fine on tiled (sway clamps).
bindsym $mod+minus       resize shrink width  50 px
bindsym $mod+equal       resize grow   width  50 px
bindsym $mod+Shift+minus resize shrink height 50 px
bindsym $mod+Shift+equal resize grow   height 50 px

bindsym $mod+F5 exec sh -lc "$HOME/.config/sway/scripts/screenshot all"
bindsym $mod+Ctrl+F5 exec sh -lc "$HOME/.config/sway/scripts/screenshot output"
bindsym $mod+Alt+F5 exec sh -lc "$HOME/.config/sway/scripts/screenshot region"

bindsym Ctrl+Alt+Delete exec $quit
