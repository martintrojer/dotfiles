#!/usr/bin/env python3
"""Lock the session with swaylock.

All the picture work (blur, banner stamp, accent pluck, cache) lives in
the `wallpaper` helper now. This script just:
  1. Reads `wallpaper status` to get the pre-rendered lock image + accent.
  2. Builds a swaylock command using those.
  3. Falls back to a solid-color lock if anything's missing.
  4. exec's into swaylock.

Locking must always succeed. If `wallpaper` is unavailable, the JSON is
malformed, the cached image is missing, or magick failed during the
last `wallpaper set/use` — we still launch swaylock with the Catppuccin
base color so the session is locked.

Unknown flags pass through to swaylock verbatim (`parse_known_args`),
so callers like `session-swayidle` can keep passing e.g. `--daemonize`.
"""
from __future__ import annotations

import argparse
import json
import os
import shlex
import shutil
import subprocess
import sys
from pathlib import Path


WALLPAPER_HELPER = Path.home() / ".local" / "bin" / "wallpaper"
FALLBACK_COLOR = "1e1e2e"  # Catppuccin Mocha base


def parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog="lock-screen",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument(
        "--print-command",
        action="store_true",
        help="print the swaylock command that would run, then exit (dry-run)",
    )
    args, passthrough = p.parse_known_args(argv)
    if passthrough and passthrough[0] == "--":
        passthrough = passthrough[1:]
    args.swaylock_args = passthrough
    return args


def wallpaper_status() -> dict | None:
    """Return the parsed `wallpaper status` JSON, or None on any failure."""
    if not os.access(WALLPAPER_HELPER, os.X_OK):
        return None
    try:
        res = subprocess.run(
            [str(WALLPAPER_HELPER), "status"],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if res.returncode != 0:
        return None
    try:
        data = json.loads(res.stdout)
    except (ValueError, json.JSONDecodeError):
        return None
    if not isinstance(data, dict):
        return None
    return data


def build_swaylock_cmd(passthrough: list[str]) -> list[str]:
    """Build the swaylock command from `wallpaper status`, with fallbacks.

    Decision tree:
      - wallpaper helper missing OR no current wallpaper      -> solid color
      - lock_image present and on disk                         -> -i lock_image
      - lock_image missing but wallpaper path present and OK   -> -i wallpaper
        (raw wallpaper, no blur/banner — degraded but still locked)
      - everything missing                                     -> solid color

    The accent ring is added when present and valid, regardless of
    which image path we end up using.
    """
    status = wallpaper_status()

    image: Path | None = None
    accent: str | None = None
    if status:
        accent_v = status.get("accent")
        if isinstance(accent_v, str) and len(accent_v) == 6:
            accent = accent_v
        for key in ("lock_image", "path"):
            v = status.get(key)
            if isinstance(v, str) and Path(v).is_file():
                image = Path(v)
                break

    if image is None:
        return ["swaylock", "--color", FALLBACK_COLOR, *passthrough]

    cmd = ["swaylock"]
    if accent is not None:
        cmd += ["--ring-color", f"{accent}ff", "--key-hl-color", f"{accent}ff"]
    cmd += ["--image", str(image), "--scaling", "fill", *passthrough]
    return cmd


def exec_swaylock(cmd: list[str], *, dry_run: bool) -> int:
    if dry_run:
        print(shlex.join(cmd))
        return 0
    if shutil.which(cmd[0]) is None:
        print(f"lock-screen: {cmd[0]} not on PATH", file=sys.stderr)
        return 127
    try:
        os.execvp(cmd[0], cmd)
    except OSError as e:
        print(f"lock-screen: failed to exec {cmd[0]}: {e}", file=sys.stderr)
        return 1


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    cmd = build_swaylock_cmd(args.swaylock_args)
    rc = exec_swaylock(cmd, dry_run=args.print_command)
    return rc if rc is not None else 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
