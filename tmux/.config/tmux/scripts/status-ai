#!/usr/bin/env python3
"""Render the tmux AI attention status segment."""

from __future__ import annotations

import os
import subprocess
import sys
import time
from pathlib import Path


SCRIPT = Path(__file__).with_name("agent-attention")
STATE_DIR = (
    Path(os.environ.get("XDG_STATE_HOME") or Path.home() / ".local" / "state")
    / "tmux-agent-attention"
)
ERROR_LOG = STATE_DIR / "status-ai.log"
ERROR_LOG_THROTTLE_SECONDS = 60 * 60  # one breadcrumb per hour


def log_error(message: str) -> None:
    """Append a throttled error breadcrumb so silent failures stay debuggable."""
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        now = time.time()
        if ERROR_LOG.is_file():
            mtime = ERROR_LOG.stat().st_mtime
            if now - mtime < ERROR_LOG_THROTTLE_SECONDS:
                return
        with ERROR_LOG.open("a", encoding="utf-8") as handle:
            handle.write(f"{int(now)}\t{message}\n")
    except OSError:
        return


def agent_attention_count() -> str:
    try:
        return subprocess.check_output(
            [str(SCRIPT), "status"], text=True, stderr=subprocess.DEVNULL
        ).strip()
    except (OSError, subprocess.CalledProcessError) as exc:
        log_error(f"agent-attention status failed: {exc}")
        return ""


def main() -> None:
    # Caller in tmux/.tmux.conf wraps this with the AI badge style.
    # We emit the badge content and then reset style + a trailing spacer
    # so the gap before the next segment only appears when the badge
    # itself does (no badge -> no orphaned gap).
    count = agent_attention_count()
    if count:
        sys.stdout.write(f" AI {count} #[default]  ")


if __name__ == "__main__":
    main()
