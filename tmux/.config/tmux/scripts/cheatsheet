#!/usr/bin/env bash
# Tmux cheatsheet picker — fzf over keybindings
set -euo pipefail

entries="
── Sessions ──
d         Detach from session
s         Session picker
S         Switch session (tree picker)
g         Last session
T         Root session from cwd
\$         Rename session

── Windows ──
c         New window
w         Session-window tree picker
n  /  p   Next / previous window
0-9       Go to window by number
,         Rename window
&         Kill window

── Panes ──
\"         Horizontal split
%         Vertical split
!         Break current pane into new window
M         Move current pane into selected window/pane
C-hjkl    Move between panes/vim (no prefix)
;         Last pane
o         Next pane
z         Zoom / unzoom pane
x         Kill pane
{ / }     Swap pane up / down

── Resize ──
M-arrows  Resize pane by 5 (repeatable)
V         Cycle split 1/3 → 1/2 → 2/3

── Copy & Pick ──
[         Enter copy mode
h         Thumbs hint picker
v         Clipboard history (fzf)
]         Paste buffer
=         Buffer list
y         Copy current line

── Tools ──
F         tmux-fzf menu
C-g       Cheatsheet (this)
A         AI attention picker
?         List all keybindings
I         Install plugins (TPM)

── Other ──
C-q       Clear pane history (no prefix)
:         Command prompt
t         Clock
"

echo "$entries" | grep -v '^$' | fzf --prompt="cheatsheet> " --reverse --no-multi --ansi || true
