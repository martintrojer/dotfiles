#!/usr/bin/env python3
"""Render a smarter tmux window label from active-pane metadata.

Called per visible window from window-status-format. tmux evaluates
the format-string variables in the context of the window's active
pane, so we receive the relevant fields directly as positional args
and avoid re-querying tmux.

Usage:
    status-window-label <window_name> <pane_current_command> \\
                        <pane_title> <pane_current_path> <host> <pane_pid>

Customise the agent/editor/shell lists by exporting the matching env
vars before tmux starts (space-separated):

    export TMUX_LABEL_AGENTS="claude codex pi opencode aider"

Why a Python rewrite of a former /bin/sh script: the bash version
embedded an awk BFS over ps output to find an agent in a pane's
descendant process tree. ps-pipeline + awk is the classic shell smell
flagged in AGENTS.md; the Python version keeps the same algorithm
with explicit data structures and shares the status-bar error
plumbing (`EXPECTED_ERRORS`, `log_error`) with the rest of the tmux
status scripts.
"""

from __future__ import annotations

import os
import subprocess
import sys
from collections import deque

from _status_common import EXPECTED_ERRORS, log_error

# ---------------------------------------------------------------------
# Configurable word lists. Defaults match the bash version; env-var
# overrides preserve the previous customisation contract.
# ---------------------------------------------------------------------


def _env_list(name: str, default: str) -> tuple[str, ...]:
    return tuple(os.environ.get(name, default).split())


SHELLS = _env_list("TMUX_LABEL_SHELLS", "zsh bash sh fish nu")
EDITORS = _env_list("TMUX_LABEL_EDITORS", "nvim vim vi hx helix kak emacs nano")
AGENTS = _env_list("TMUX_LABEL_AGENTS", "claude codex pi opencode")
# Wrapper interpreters that often *host* an agent rather than being one.
# When the active command is one of these we walk the descendant
# process tree to find the real agent.
AGENT_WRAPPERS = _env_list(
    "TMUX_LABEL_AGENT_WRAPPERS", "Python python python3 node nodejs bun deno"
)
# Helpers an agent may exec into (man/less/etc); same descendant-walk
# trigger so the label keeps tracking the agent through helper drilldowns.
AGENT_HELPERS = _env_list("TMUX_LABEL_AGENT_HELPERS", "less more man")


# ---------------------------------------------------------------------
# Predicates
# ---------------------------------------------------------------------


def has_meaningful_title(pane_title: str, host_name: str) -> bool:
    """`pane_title` is meaningful when it's non-empty, isn't the host
    name, and doesn't look like a path-ish leftover (``:/foo``, ``/foo``,
    ``~/foo``).
    """
    if not pane_title or pane_title == host_name:
        return False
    return not pane_title.startswith((":", "/", "~"))


def detect_agent_in_tree(root_pid: str, agents: tuple[str, ...]) -> str | None:
    """Walk the descendant process tree of ``root_pid``; return the
    first descendant command matching ``agents`` (basename match), or
    ``None``.

    This is the most trustworthy agent signal because both
    ``pane_title`` and ``window_name`` can be stale leftovers from a
    previous tenant of the pane (e.g. an old "Claude Code" title when
    the running process is now Pi).
    """
    if not root_pid:
        return None
    try:
        res = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,comm="],
            capture_output=True,
            text=True,
            check=False,
            timeout=5,
        )
    except EXPECTED_ERRORS:
        return None
    if res.returncode != 0:
        return None

    wanted = frozenset(agents)
    # Build (pid -> [child_pid, ...]) and (pid -> basename(comm))
    children: dict[str, list[str]] = {}
    comm: dict[str, str] = {}
    for line in res.stdout.splitlines():
        parts = line.split(None, 2)
        if len(parts) < 3:
            continue
        pid, ppid, cmd = parts
        comm[pid] = cmd.rsplit("/", 1)[-1]
        children.setdefault(ppid, []).append(pid)

    queue: deque[str] = deque([root_pid])
    seen: set[str] = set()
    while queue:
        cur = queue.popleft()
        if cur in seen:
            continue
        seen.add(cur)
        if comm.get(cur) in wanted:
            return comm[cur]
        queue.extend(children.get(cur, ()))
    return None


# ---------------------------------------------------------------------
# Main label dispatch (mirrors the bash precedence chain)
# ---------------------------------------------------------------------


def render(
    *,
    window_name: str,
    pane_current_command: str,
    pane_title: str,
    pane_current_path: str,
    host_name: str,
    pane_pid: str,
) -> str:
    path_base = pane_current_path.rsplit("/", 1)[-1] if pane_current_path else ""
    meaningful = has_meaningful_title(pane_title, host_name)

    # Editors: always show their own command (nvim/vim/etc.).
    if pane_current_command in EDITORS:
        return pane_current_command

    # Shells: prefer the user-set title, fall back to cwd basename,
    # then window name, then the shell command itself.
    if pane_current_command in SHELLS:
        if meaningful:
            return pane_title
        if path_base:
            return path_base
        if window_name:
            return window_name
        return pane_current_command

    # Agent-likely: window name or active command suggests an agent
    # (or its wrapper / helper). Walk the descendant tree first;
    # pane_title / window_name can be stale here.
    if (
        window_name in AGENTS
        or pane_current_command in AGENT_WRAPPERS
        or pane_current_command in AGENT_HELPERS
    ):
        detected = detect_agent_in_tree(pane_pid, AGENTS)
        if detected:
            return detected
        if meaningful:
            return pane_title
        if (
            pane_current_command in AGENT_WRAPPERS
            or pane_current_command in AGENT_HELPERS
        ):
            return window_name
        if pane_current_command:
            return pane_current_command
        return window_name

    # Default fallback chain for everything else.
    if meaningful:
        return pane_title
    if pane_current_command:
        return pane_current_command
    if path_base:
        return path_base
    return window_name


def main(argv: list[str]) -> int:
    # Pad missing positional args to empty strings so callers that
    # omit trailing fields don't crash. Matches the bash version's
    # `${N-}` default behaviour.
    args = (argv + [""] * 6)[:6]
    try:
        label = render(
            window_name=args[0],
            pane_current_command=args[1],
            pane_title=args[2],
            pane_current_path=args[3],
            host_name=args[4],
            pane_pid=args[5],
        )
    except EXPECTED_ERRORS as exc:
        log_error("status-window-label", f"render failed: {exc!r}")
        # Best-effort fallback: print whatever window_name we got.
        label = args[0]
    sys.stdout.write(label)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
