#!/bin/sh
# Render a short uptime string for tmux on macOS and Linux.
#
# Pure sh on purpose: this runs every tmux status-interval (5 s),
# and uptime only needs one cheap OS query plus integer arithmetic.
# Avoiding a Python interpreter cold-start keeps the status tick small
# without adding a daemon or cache file for a value that changes once a
# minute.

fmt() { # $1 = total seconds -> "Nd Nh" / "Nh Nm" / "Nm"
	mins=$(( $1 / 60 ))
	days=$(( mins / 1440 ))
	rem=$(( mins % 1440 ))
	hours=$(( rem / 60 ))
	m=$(( rem % 60 ))
	if [ "$days" -gt 0 ]; then
		printf '%dd %dh' "$days" "$hours"
	elif [ "$hours" -gt 0 ]; then
		printf '%dh %dm' "$hours" "$m"
	else
		printf '%dm' "$m"
	fi
}

case "$(uname -s)" in
Linux)
	# /proc/uptime first field is seconds since boot (float).
	read -r up _ </proc/uptime 2>/dev/null || { printf 'up ?'; exit 0; }
	fmt "${up%%.*}"
	;;
Darwin)
	# kern.boottime looks like: { sec = 1700000000, usec = 0 } ...
	bt=$(sysctl -n kern.boottime 2>/dev/null)
	sec=${bt#*sec = }
	sec=${sec%%,*}
	case "$sec" in
	'' | *[!0-9]*) printf 'up ?'; exit 0 ;;
	esac
	now=$(date +%s)
	diff=$(( now - sec ))
	[ "$diff" -lt 0 ] && diff=0
	fmt "$diff"
	;;
*)
	printf 'up ?'
	;;
esac
