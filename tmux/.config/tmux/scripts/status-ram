#!/usr/bin/env python3
"""Render RAM usage percentage for tmux on macOS and Linux."""

from __future__ import annotations

import platform
import re
import subprocess

LOW_STYLE = "#[bg=#313244]#[fg=#a6adc8]"
MEDIUM_STYLE = "#[bg=#313244]#[fg=#fab387]"
HIGH_STYLE = "#[bg=#313244]#[fg=#cdd6f4]"
MEDIUM_THRESH = 75
HIGH_THRESH = 90


def ram_percentage() -> int:
    system = platform.system()
    if system == "Linux":
        info: dict[str, int] = {}
        with open("/proc/meminfo", "r", encoding="utf-8") as handle:
            for line in handle:
                key, value = line.split(":", 1)
                match = re.search(r"(\d+)", value)
                if match is not None:
                    info[key] = int(match.group(1))
        total = info["MemTotal"]
        available = info.get("MemAvailable", info["MemFree"])
        used = max(0, total - available)
        return round((used / total) * 100)

    if system == "Darwin":
        vm_stat = subprocess.check_output(["vm_stat"], text=True)
        counts: dict[str, int] = {}
        for line in vm_stat.splitlines():
            match = re.match(r"^([^:]+):\s+(\d+)\.$", line.strip())
            if match is not None:
                counts[match.group(1)] = int(match.group(2))
        total = int(subprocess.check_output(["sysctl", "-n", "hw.memsize"], text=True))
        used_pages = (
            counts.get("Pages active", 0)
            + counts.get("Pages speculative", 0)
            + counts.get("Pages wired down", 0)
        )
        total_pages = sum(
            counts.get(key, 0)
            for key in (
                "Pages free",
                "Pages active",
                "Pages inactive",
                "Pages speculative",
                "Pages wired down",
                "Pages occupied by compressor",
            )
        )
        if total_pages <= 0:
            raise RuntimeError("could not derive total pages")
        return round((used_pages / total_pages) * 100)

    raise RuntimeError(f"unsupported OS: {system}")


def render_segment(percentage: int) -> str:
    if percentage >= HIGH_THRESH:
        style = HIGH_STYLE
    elif percentage >= MEDIUM_THRESH:
        style = MEDIUM_STYLE
    else:
        style = LOW_STYLE

    return f"{style}󰾆 {percentage}%"


def main() -> None:
    try:
        print(render_segment(ram_percentage()))
    except Exception:
        print("ram ?")


if __name__ == "__main__":
    main()
