#!/usr/bin/env python3
"""Session loop: cycle between a small set of pinned tmux sessions."""

import argparse
import os
import subprocess
from pathlib import Path

SCRIPT = Path(__file__).resolve()
STATE_DIR = (
    Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local" / "state")))
    / "tmux-session-loop"
)
LOOP_FILE = STATE_DIR / "sessions"


def tmux(*args: str) -> str:
    result = subprocess.run(["tmux", *args], capture_output=True, text=True)
    return result.stdout.strip()


def tmux_msg(msg: str) -> None:
    tmux("display-message", msg)


def has_session(session_id: str) -> bool:
    return (
        subprocess.run(
            ["tmux", "has-session", "-t", session_id], capture_output=True
        ).returncode
        == 0
    )


def current_session_id() -> str:
    return tmux("display-message", "-p", "#{session_id}")


def current_session_name() -> str:
    return tmux("display-message", "-p", "#S")


def session_name(session_id: str) -> str:
    """Resolve a session ID to its current name."""
    name = tmux("display-message", "-t", session_id, "-p", "#S")
    return name or session_id


def read_loop() -> list[str]:
    """Read loop file (session IDs), prune missing sessions, persist."""
    if not LOOP_FILE.exists():
        return []
    sessions = [s for s in LOOP_FILE.read_text().splitlines() if s]
    filtered = [sid for sid in sessions if has_session(sid)]
    if filtered != sessions:
        write_loop(filtered)
    return filtered


def write_loop(sessions: list[str]) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    LOOP_FILE.write_text("\n".join(sessions) + "\n" if sessions else "")


def cmd_add() -> None:
    sid = current_session_id()
    name = current_session_name()
    sessions = read_loop()
    if sid in sessions:
        tmux_msg(f"Loop: '{name}' already in loop")
        return
    sessions.append(sid)
    write_loop(sessions)
    tmux_msg(f"Loop: added '{name}' ({len(sessions)} sessions)")


def cmd_remove() -> None:
    sid = current_session_id()
    name = current_session_name()
    sessions = read_loop()
    if sid not in sessions:
        tmux_msg(f"Loop: '{name}' not in loop")
        return
    sessions.remove(sid)
    write_loop(sessions)
    tmux_msg(f"Loop: removed '{name}' ({len(sessions)} sessions)")


def cmd_toggle() -> None:
    sid = current_session_id()
    name = current_session_name()
    sessions = read_loop()
    if sid in sessions:
        sessions.remove(sid)
        write_loop(sessions)
        tmux_msg(f"Loop: removed '{name}' ({len(sessions)} sessions)")
    else:
        sessions.append(sid)
        write_loop(sessions)
        tmux_msg(f"Loop: added '{name}' ({len(sessions)} sessions)")


def cmd_next() -> None:
    _cycle(1)


def cmd_prev() -> None:
    _cycle(-1)


def _cycle(direction: int) -> None:
    sessions = read_loop()
    if len(sessions) == 0:
        tmux_msg("Loop: empty")
        return
    if len(sessions) == 1:
        tmux("switch-client", "-t", sessions[0])
        return
    sid = current_session_id()
    try:
        idx = sessions.index(sid)
    except ValueError:
        tmux("switch-client", "-t", sessions[0])
        return
    target = (idx + direction) % len(sessions)
    tmux("switch-client", "-t", sessions[target])


def cmd_list() -> None:
    sessions = read_loop()
    count = len(sessions)
    if count == 0:
        tmux("choose-tree", "-sZ", "-O", "name")
    elif count == 1:
        tmux("switch-client", "-t", sessions[0])
    elif count == 2:
        cmd_next()
    else:
        tmux(
            "display-popup",
            "-E",
            "-w",
            "50%",
            "-h",
            "40%",
            "--",
            str(SCRIPT),
            "_pick",
        )


def cmd_pick() -> None:
    """Internal: runs inside the popup, pipes session list through fzf."""
    sid = current_session_id()
    sessions = read_loop()
    # Rotate so the next session after current is at the top
    try:
        idx = sessions.index(sid)
        sessions = sessions[idx + 1 :] + sessions[: idx + 1]
    except ValueError:
        pass
    # Build fzf lines: "session_id\tDisplay Name"
    lines = []
    for s in sessions:
        name = session_name(s)
        marker = "▸" if s == sid else " "
        lines.append(f"{s}\t{marker} {name}")
    try:
        result = subprocess.run(
            [
                "fzf",
                "--no-info",
                "--reverse",
                "--no-sort",
                "--delimiter",
                "\t",
                "--with-nth",
                "2..",
            ],
            input="\n".join(lines),
            capture_output=True,
            text=True,
        )
        chosen = result.stdout.strip()
        if chosen:
            selected_id = chosen.split("\t", 1)[0]
            tmux("switch-client", "-t", selected_id)
    except FileNotFoundError:
        tmux_msg("Loop: fzf not found")


def main() -> None:
    parser = argparse.ArgumentParser(description="Tmux session loop")
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("add", help="Add current session to loop")
    sub.add_parser("remove", help="Remove current session from loop")
    sub.add_parser("toggle", help="Toggle current session in/out of loop")
    sub.add_parser("next", help="Switch to next session in loop")
    sub.add_parser("prev", help="Switch to previous session in loop")
    sub.add_parser("list", help="Smart picker: tree / toggle / fzf popup")
    sub.add_parser("_pick", help=argparse.SUPPRESS)

    args = parser.parse_args()
    commands = {
        "add": cmd_add,
        "remove": cmd_remove,
        "toggle": cmd_toggle,
        "next": cmd_next,
        "prev": cmd_prev,
        "list": cmd_list,
        "_pick": cmd_pick,
        None: cmd_list,
    }
    commands[args.command]()


if __name__ == "__main__":
    main()
