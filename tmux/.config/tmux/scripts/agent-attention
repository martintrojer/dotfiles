#!/usr/bin/env python3
"""Track AI agent state per tmux window and surface it in tmux UI.

State model:
  working  — agent is running (set by pi extension directly)
  blocked  — agent waiting on user (pi extension or legacy notify)
  crashed  — agent died unexpectedly (reaper: pid gone while working)
  cleared  — explicit clear; resets to none

The pi extension is the authoritative writer of @agent_state for
normal transitions.  This script handles:
  - ``notify``: legacy path for non-pi agents (codex/opencode)
  - ``status``: crash reaper + state counting for the status pill
  - ``clear-current`` / ``clear-target``: focus-clear hooks
  - ``menu``: the prefix+a picker
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import sqlite3
import subprocess
import time
from pathlib import Path
from typing import NamedTuple

from _tmux_common import (
    STATE_GLYPH,
    AgentState,
    AgentStats,
    ProcessSnapshot,
    scan_agent_states,
    tmux_cmd,
)

STATE_DIR = (
    Path(os.environ.get("XDG_STATE_HOME") or Path.home() / ".local" / "state")
    / "tmux-agent-attention"
)
DB_PATH = STATE_DIR / "events.db"
MAX_EVENTS = 4000
ENABLE_SYSTEM_NOTIFY_ENV = "TMUX_AGENT_ATTENTION_ENABLE_SYSTEM_NOTIFY"
DISABLE_SYSTEM_NOTIFY_ENV = "TMUX_AGENT_ATTENTION_DISABLE_SYSTEM_NOTIFY"


# ---------- tmux helpers ----------


def tmux_exists() -> bool:
    return shutil.which("tmux") is not None


def tmux(args: list[str], check: bool = True) -> str:
    """agent-attention's local convenience wrapper: takes a list,
    returns stripped stdout, and re-raises non-zero exits as
    ``RuntimeError`` with the most useful stream text we have. Built
    on `_tmux_common.tmux_cmd` so the socket-env honoring is shared.
    """
    result = tmux_cmd(*args, check=False)
    if check and result.returncode != 0:
        msg = result.stderr.strip() or result.stdout.strip() or "tmux command failed"
        raise RuntimeError(msg)
    return result.stdout.strip()


def tmux_query(target: str | None, fields: list[str]) -> list[str] | None:
    """Run display-message with a list of #{...} fields, return parts or None."""
    fmt = "\t".join(fields)
    args = ["display-message", "-p"]
    if target:
        args += ["-t", target]
    args.append(fmt)
    out = tmux(args, check=False)
    if not out:
        return None
    parts = out.split("\t")
    return parts if len(parts) == len(fields) else None


def sanitize(value: str) -> str:
    return value.replace("\t", " ").replace("\n", " ").replace("\r", " ").strip()


def to_int(value: object, default: int = 0) -> int:
    if isinstance(value, (int, str, bytes, bytearray)):
        try:
            return int(value)
        except (TypeError, ValueError):
            pass
    return default


# ---------- pane resolution ----------


def find_tty() -> str | None:
    """Resolve the controlling TTY for the current process.

    Fast path: ``os.ttyname(fd)`` for stdin/stdout/stderr — zero forks when
    the script is run interactively or from a tmux pane that inherited a
    TTY on at least one standard fd.

    Slow path: walk up the process tree from a single ``ps`` snapshot,
    used for hook subprocesses (systemd, agent harnesses) where none of
    fd0/1/2 is a TTY. We cap the walk at 8 ancestor levels. The previous
    implementation forked ``ps`` twice per level (up to 16 forks); one
    snapshot indexed by pid is one fork total.

    On macOS ``ps -o tty=`` outputs ``??`` for processes with no
    controlling tty (Linux uses ``?``). Treat any all-``?`` value as
    no-tty.
    """
    for fd in (0, 1, 2):
        try:
            return os.ttyname(fd)
        except OSError:
            continue

    try:
        rows = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,tty="],
            capture_output=True,
            text=True,
        ).stdout
    except OSError:
        return None

    by_pid: dict[str, tuple[str, str]] = {}
    for line in rows.splitlines():
        parts = line.split(None, 2)
        if len(parts) == 3:
            by_pid[parts[0]] = (parts[1], parts[2])

    pid = str(os.getpid())
    for _ in range(8):
        info = by_pid.get(pid)
        if info is None:
            return None
        ppid, tty = info
        if tty and tty.strip("?"):
            return f"/dev/{tty}"
        pid = ppid
    return None


def pane_from_tty() -> str | None:
    """Map controlling TTY → tmux pane id (first match wins)."""
    tty = find_tty()
    if not tty:
        return None
    out = tmux(["list-panes", "-a", "-F", "#{pane_tty}\t#{pane_id}"], check=False)
    for row in out.splitlines():
        parts = row.split("\t", 1)
        if len(parts) == 2 and parts[0] == tty:
            return parts[1]
    return None


CONTEXT_FIELDS = [
    "#{session_id}",
    "#{session_name}",
    "#{window_id}",
    "#{window_index}",
    "#{window_name}",
    "#{pane_id}",
    "#{pane_active}",
    "#{window_active}",
    "#{session_attached}",
]
CONTEXT_KEYS = [
    "session_id",
    "session_name",
    "window_id",
    "window_index",
    "window_name",
    "pane_id",
    "pane_active",
    "window_active",
    "session_attached",
]


def current_context(pane: str | None) -> dict[str, str] | None:
    target = pane or os.environ.get("TMUX_PANE") or pane_from_tty()
    if not target:
        return None
    parts = tmux_query(target, CONTEXT_FIELDS)
    return dict(zip(CONTEXT_KEYS, parts, strict=True)) if parts else None


# ---------- event store (SQLite WAL) ----------

_CREATE_SQL = """
CREATE TABLE IF NOT EXISTS events (
    ts       INTEGER NOT NULL,
    session_id   TEXT NOT NULL DEFAULT '',
    session_name TEXT NOT NULL DEFAULT '',
    window_id    TEXT NOT NULL DEFAULT '',
    window_index TEXT NOT NULL DEFAULT '',
    window_name  TEXT NOT NULL DEFAULT '',
    pane_id      TEXT NOT NULL DEFAULT '',
    source       TEXT NOT NULL DEFAULT '',
    state        TEXT NOT NULL DEFAULT '',
    message      TEXT NOT NULL DEFAULT '',
    pid          INTEGER,
    synthetic    INTEGER NOT NULL DEFAULT 0,
    reason       TEXT NOT NULL DEFAULT ''
);
CREATE INDEX IF NOT EXISTS idx_events_window ON events(window_id);
"""


def _db() -> sqlite3.Connection:
    """Open (or create) the events database with WAL mode."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH), timeout=5)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.executescript(_CREATE_SQL)
    return conn


def insert_event(
    *,
    session_id: str = "",
    session_name: str = "",
    window_id: str = "",
    window_index: str = "",
    window_name: str = "",
    pane_id: str = "",
    source: str = "",
    state: str = "",
    message: str = "",
    pid: int | None = None,
    synthetic: bool = False,
    reason: str = "",
) -> None:
    """Insert a single event row."""
    with _db() as conn:
        conn.execute(
            "INSERT INTO events (ts,session_id,session_name,window_id,window_index,"
            "window_name,pane_id,source,state,message,pid,synthetic,reason) "
            "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (
                int(time.time()),
                session_id,
                session_name,
                window_id,
                window_index,
                window_name,
                pane_id,
                source,
                state,
                message,
                pid,
                int(synthetic),
                reason,
            ),
        )


def prune_stale_events() -> None:
    """Remove events for windows that no longer exist and trim to MAX_EVENTS."""
    targets = set()
    out = tmux(["list-windows", "-a", "-F", "#{window_id}"], check=False)
    for line in out.splitlines():
        wid = line.strip()
        if wid:
            targets.add(wid)
    with _db() as conn:
        if targets:
            placeholders = ",".join("?" for _ in targets)
            conn.execute(
                f"DELETE FROM events WHERE window_id NOT IN ({placeholders})",
                list(targets),
            )
        else:
            conn.execute("DELETE FROM events")
        # Trim old events.
        conn.execute(
            "DELETE FROM events WHERE rowid NOT IN "
            "(SELECT rowid FROM events ORDER BY ts DESC LIMIT ?)",
            (MAX_EVENTS,),
        )


def clear_events_for_window(window_id: str) -> None:
    """Delete all events for a window."""
    with _db() as conn:
        conn.execute("DELETE FROM events WHERE window_id = ?", (window_id,))


def event_summary_by_window() -> dict[str, dict[str, object]]:
    """Latest timestamp, source, and message per window."""
    conn = _db()
    conn.row_factory = sqlite3.Row
    rows = conn.execute(
        "SELECT window_id, MAX(ts) as last_ts, source, message "
        "FROM events GROUP BY window_id"
    ).fetchall()
    return {
        row["window_id"]: {
            "last_ts": row["last_ts"],
            "src": row["source"] or "",
            "msg": row["message"] or "",
        }
        for row in rows
    }


# ---------- notifications ----------


def send_osc777(title: str, message: str) -> None:
    """Emit OSC 777 to the controlling TTY, wrapping in DCS passthrough inside tmux."""
    tty = find_tty()
    if not tty:
        return
    osc = f"\x1b]777;notify;{title};{message}\x07"
    if os.environ.get("TMUX"):
        osc = f"\x1bPtmux;\x1b{osc}\x1b\\"
    try:
        with open(tty, "w") as f:
            f.write(osc)
    except OSError:
        pass


def system_notifications_enabled() -> bool:
    # Desktop notifications are opt-in. Keep honoring the old disable flag as
    # an explicit off switch in case an environment enables them globally.
    if os.environ.get(DISABLE_SYSTEM_NOTIFY_ENV, "").strip().lower() in {
        "1",
        "true",
        "yes",
        "on",
    }:
        return False
    return os.environ.get(ENABLE_SYSTEM_NOTIFY_ENV, "").strip().lower() in {
        "1",
        "true",
        "yes",
        "on",
    }


def send_system_notification(fields: dict[str, object]) -> None:
    if not system_notifications_enabled():
        return

    title = str(fields.get("title") or "Agent notification")
    message = str(fields.get("message", ""))
    source = str(fields.get("source", ""))
    event_type = str(fields.get("type", ""))
    if source or event_type:
        prefix = f"[{source}/{event_type}]".strip("/")
        message = f"{prefix} {message}".strip()
    icon_title = f"🤖 {title}"

    osascript = shutil.which("osascript")
    notify_send = shutil.which("notify-send")
    try:
        if osascript:
            qt = json.dumps(icon_title)
            qm = json.dumps(message)
            subprocess.run(
                [osascript, "-e", f"display notification {qm} with title {qt}"],
                check=False,
                capture_output=True,
                text=True,
            )
        elif notify_send:
            subprocess.run(
                [notify_send, icon_title, message],
                check=False,
                capture_output=True,
                text=True,
            )
    except OSError:
        pass


# ---------- attention state on tmux side ----------


def set_state(window_id: str, state: AgentState | None) -> None:
    """Set @agent_state (and @pane_agent) on a tmux window.

    @pane_agent is sticky — once set it persists until the pane dies,
    so idle detection works even across container boundaries where
    process-tree scanning can't see the agent.
    """
    if state and state.visible:
        tmux(
            ["set-window-option", "-q", "-t", window_id, "@agent_state", state.name],
            check=False,
        )
        # Mark window as hosting an agent (sticky: survives state clears).
        tmux(
            ["set-window-option", "-q", "-t", window_id, "@pane_agent", "1"],
            check=False,
        )
    else:
        tmux(
            ["set-window-option", "-qu", "-t", window_id, "@agent_state"],
            check=False,
        )
        # @pane_agent intentionally NOT cleared — it's sticky.


def clear_target(session_id: str | None, window_id: str) -> None:
    """Clear attention state for a window on focus.

    Only clears ``blocked`` and ``crashed`` — these are "look at me"
    states the user acknowledges by focusing.  ``working`` means the
    agent is still active; focusing doesn't change that.
    """
    cur = AgentState.parse(
        tmux(
            ["display-message", "-p", "-t", window_id, "#{@agent_state}"],
            check=False,
        )
    )
    if cur is AgentState.working:
        return
    set_state(window_id, None)
    clear_events_for_window(window_id)
    tmux(["refresh-client", "-S"], check=False)


def resolve_target(target: str) -> tuple[str | None, str] | None:
    target = target.strip()
    if not target:
        return None
    if ":" in target:
        sid, wid = target.split(":", 1)
        return (sid, wid) if sid and wid else None
    if target.startswith("@"):
        return None, target
    return None


# ---------- subcommands ----------


def cmd_notify(args: argparse.Namespace) -> int:
    """Legacy notify path for non-pi agents (e.g. codex/opencode).

    Sets @agent_state=blocked and inserts a DB event.  Pi agents
    bypass this entirely and write tmux options + DB rows directly
    from the extension via the ``event`` subcommand.
    """
    if not tmux_exists():
        return 0
    ctx = current_context(args.pane)
    if ctx is None:
        return 0

    insert_event(
        session_id=ctx["session_id"],
        session_name=ctx["session_name"],
        window_id=ctx["window_id"],
        window_index=ctx["window_index"],
        window_name=ctx["window_name"],
        pane_id=ctx["pane_id"],
        source=sanitize(args.source or "agent"),
        state=AgentState.blocked.name,
        message=sanitize(args.message or "attention"),
    )
    set_state(ctx["window_id"], AgentState.blocked)
    tmux(["refresh-client", "-S"], check=False)
    return 0


def cmd_event(args: argparse.Namespace) -> int:
    """Record an event and set @agent_state.  Called by the pi extension.

    Unlike ``notify``, this takes explicit --window and --state flags
    and does not resolve pane context.  Handles working/blocked/cleared
    transitions and sets @pane_agent as a sticky marker.
    """
    if not tmux_exists():
        return 0
    window_id = args.window
    state = args.state
    # Resolve session context from window_id.
    ctx_raw = tmux_query(
        window_id,
        [
            "#{session_id}",
            "#{session_name}",
            "#{window_index}",
            "#{window_name}",
        ],
    )
    if not ctx_raw:
        return 0
    sid, sname, widx, wname = ctx_raw

    insert_event(
        session_id=sid,
        session_name=sname,
        window_id=window_id,
        window_index=widx,
        window_name=wname,
        source="pi",
        state=state,
        message=state,
        pid=args.pid,
    )
    if state == "cleared":
        set_state(window_id, None)
    elif state == "blocked":
        set_state(window_id, AgentState.blocked)
    elif state == "working":
        set_state(window_id, AgentState.working)
    tmux(["refresh-client", "-S"], check=False)
    return 0


# ---------- reaper and reconciler ----------


def pid_alive(pid: int) -> bool:
    """Check whether a process is still running (zero-fork, one syscall)."""
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        # Different uid but pid exists — treat as alive to be safe.
        return True
    except (OSError, TypeError, ValueError):
        return False


class WindowState(NamedTuple):
    state: AgentState | None
    event: sqlite3.Row | None


def compute_window_state(events: list[sqlite3.Row]) -> WindowState:
    """Determine the current state for a window from its events.

    Scans newest-first.  Rules:
      - blocked: terminal, wins immediately.
      - cleared: resets to none.
      - crashed (synthesized): sticky, wins.
      - working: only if pid is still alive; otherwise synthesize crashed.
    """
    for event in reversed(events):
        state = AgentState.parse(event["state"], AgentState.blocked)
        if state is AgentState.blocked:
            return WindowState(AgentState.blocked, event)
        if state is AgentState.cleared:
            return WindowState(None, None)
        if state is AgentState.crashed:
            return WindowState(AgentState.crashed, event)
        if state is AgentState.working:
            pid = to_int(event["pid"] or 0, 0)
            if pid > 0 and pid_alive(pid):
                return WindowState(AgentState.working, event)
            return WindowState(AgentState.crashed, event)
    return WindowState(None, None)


def synthesize_crash(source_event: sqlite3.Row, *, reason: str = "pid_gone") -> None:
    """Insert a synthetic crashed event from a stale working event."""
    insert_event(
        session_id=source_event["session_id"],
        session_name=source_event["session_name"],
        window_id=source_event["window_id"],
        window_index=source_event["window_index"],
        window_name=source_event["window_name"],
        pane_id=source_event["pane_id"],
        source=source_event["source"] or "reaper",
        state=AgentState.crashed.name,
        message=f"crashed ({reason})",
        pid=source_event["pid"],
        synthetic=True,
        reason=reason,
    )


def reconcile_window_states() -> AgentStats:
    """Detect crashes and count window states for the status segment.

    The extension is the authoritative writer of @agent_state for
    normal transitions (working/blocked/cleared).  The reconciler
    only writes @agent_state when it detects a crash (pid gone while
    working).  For all other states it reads the tmux option without
    overwriting it.

    Returns {state: count} for the status pill.
    """
    prune_stale_events()

    # --- crash detection from DB ---
    conn = _db()
    conn.row_factory = sqlite3.Row
    window_ids = [
        row[0]
        for row in conn.execute("SELECT DISTINCT window_id FROM events").fetchall()
    ]
    for wid in window_ids:
        win_events = conn.execute(
            "SELECT * FROM events WHERE window_id = ? ORDER BY ts ASC",
            (wid,),
        ).fetchall()
        ws = compute_window_state(win_events)
        if ws.state is AgentState.crashed and ws.event and not ws.event["synthetic"]:
            set_state(wid, AgentState.crashed)
            synthesize_crash(ws.event)
            send_system_notification(
                {
                    "source": ws.event["source"] or "reaper",
                    "type": "crashed",
                    "title": "Pi",
                    "message": f"crashed (pid {ws.event['pid']} gone)",
                }
            )
            send_osc777("Pi", f"crashed (pid {ws.event['pid']} gone)")

    # --- count states from tmux options (authoritative) ---
    return scan_agent_states()


def cmd_status(_: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    stats = reconcile_window_states()
    worst = stats.worst_state
    if worst is None:
        return 0
    count = getattr(stats, worst.name, 0)
    print(f"{worst.name}\t{count}", end="")
    return 0


def cmd_clear_current(args: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    # Tmux hooks run as a server subprocess, so TMUX_PANE is not set and
    # find_tty() can't resolve the focused pane. The hooks pass the
    # target pane explicitly via --pane #{pane_id}.
    ctx = current_context(args.pane)
    if ctx is None:
        return 0
    clear_target(ctx["session_id"], ctx["window_id"])
    return 0


def cmd_clear_target(args: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    resolved = resolve_target(args.target)
    if resolved is None:
        return 1
    clear_target(*resolved)
    return 0


# ---------- menu ----------


def format_relative(ts: int) -> str:
    if ts <= 0:
        return ""
    age = max(0, int(time.time()) - ts)
    if age < 60:
        return f"{age}s"
    if age < 3600:
        return f"{age // 60}m"
    if age < 86400:
        return f"{age // 3600}h"
    return f"{age // 86400}d"


def attention_windows() -> list[dict[str, str]]:
    out = tmux(
        [
            "list-windows",
            "-a",
            "-F",
            "#{session_id}\t#{session_name}\t#{window_id}\t#{window_index}\t#{window_name}\t#{@agent_state}",
        ],
        check=False,
    )
    windows: list[dict[str, str]] = []
    for row in out.splitlines():
        parts = row.split("\t")
        if len(parts) == 6:
            ws = AgentState.parse(parts[5])
            if ws and ws.visible:
                windows.append(
                    {
                        "session_id": parts[0],
                        "session_name": parts[1],
                        "window_id": parts[2],
                        "window_index": parts[3],
                        "window_name": parts[4],
                        "state": parts[5],
                    }
                )
    return windows


# ANSI-colored glyphs for fzf --ansi display.
STATE_GLYPH_ANSI: dict[AgentState, str] = {
    AgentState.crashed: f"\033[1;31m{STATE_GLYPH[AgentState.crashed]}\033[0m",
    AgentState.blocked: f"\033[33m{STATE_GLYPH[AgentState.blocked]}\033[0m",
    AgentState.working: STATE_GLYPH[AgentState.working],
    AgentState.idle: f"\033[2m{STATE_GLYPH[AgentState.idle]}\033[0m",
}


class PickerRow(NamedTuple):
    """Structured data for one row in the prefix+a picker."""

    target: str  # sid:wid for tmux switch-client
    glyph: str  # ANSI-colored state glyph
    location: str  # session:window_index
    name: str  # window name
    age: str  # relative timestamp
    sort_key: tuple[int, int, int]  # (-urgency, is_mu, -last_ts)


def build_menu_rows() -> list[PickerRow]:
    """Active-state rows for the picker, sorted by urgency then recency."""
    prune_stale_events()
    summary = event_summary_by_window()

    rows: list[PickerRow] = []
    for window in attention_windows():
        sid, wid = window["session_id"], window["window_id"]
        sname = window["session_name"]
        ws = AgentState.parse(window.get("state"), AgentState.blocked)
        urgency = int(ws) if ws else 0
        is_mu = 1 if sname.startswith("mu-") else 0
        details = summary.get(wid, {})
        last_ts = to_int(details.get("last_ts", 0))
        glyph = STATE_GLYPH_ANSI.get(ws, "?") if ws else "?"
        rows.append(
            PickerRow(
                target=f"{sid}:{wid}",
                glyph=glyph,
                location=f"{sname}:{window['window_index']}",
                name=window["window_name"],
                age=format_relative(last_ts) if last_ts else "",
                sort_key=(-urgency, is_mu, -last_ts),
            )
        )
    rows.sort(key=lambda r: r.sort_key)
    return rows


def idle_agent_rows(exclude_windows: set[str]) -> list[PickerRow]:
    """Idle agent rows for the picker.

    Two detection paths:
      1. Process-tree scan (``ps`` snapshot) — works for native panes.
      2. ``@pane_agent`` tmux option — set by the push path, survives
         container boundaries where the process tree is invisible.
    """
    out = tmux(
        [
            "list-panes",
            "-a",
            "-F",
            "#{session_id}\t#{session_name}\t#{window_id}\t#{window_index}"
            "\t#{window_name}\t#{pane_pid}\t#{pane_id}\t#{@pane_agent}",
        ],
        check=False,
    )
    if not out:
        return []

    ps = ProcessSnapshot()
    rows: list[PickerRow] = []
    seen_windows: set[str] = set()
    for line in out.splitlines():
        parts = line.split("\t")
        if len(parts) != 8:
            continue
        sid, sname, wid, widx, wname, pane_pid, _pane_id, pane_agent = parts
        if wid in exclude_windows or wid in seen_windows:
            continue
        agent = ps.detect_agent(pane_pid)
        if not agent and pane_agent == "1":
            agent = wname or "agent"
        if agent:
            seen_windows.add(wid)
            is_mu = 1 if sname.startswith("mu-") else 0
            rows.append(
                PickerRow(
                    target=f"{sid}:{wid}",
                    glyph=STATE_GLYPH_ANSI.get(
                        AgentState.idle, STATE_GLYPH[AgentState.idle]
                    ),
                    location=f"{sname}:{widx}",
                    name=wname,
                    age="",
                    sort_key=(0, is_mu, 0),
                )
            )
    rows.sort(key=lambda r: r.sort_key)
    return rows


def format_picker_rows(rows: list[PickerRow]) -> list[tuple[str, str]]:
    """Format rows with aligned columns for fzf display."""
    if not rows:
        return []
    loc_w = max(len(r.location) for r in rows)
    name_w = max(len(r.name) for r in rows)
    result: list[tuple[str, str]] = []
    for r in rows:
        age_part = f"  {r.age:>3}" if r.age else "     "
        label = f"{r.glyph} {r.location:<{loc_w}}  {r.name:<{name_w}}{age_part}"
        result.append((r.target, label))
    return result


def cmd_menu(_: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    active = build_menu_rows()

    active_wids: set[str] = set()
    for window in attention_windows():
        active_wids.add(window["window_id"])

    idle = idle_agent_rows(active_wids)
    all_rows = active + idle

    if not all_rows:
        print("No agent windows found.")
        return 0

    formatted = format_picker_rows(all_rows)

    fzf = shutil.which("fzf")
    if fzf is None:
        for _target, label in formatted:
            print(label)
        return 0

    # Build prompt with state counts.
    stats = scan_agent_states()
    prompt_parts: list[str] = []
    for state in (
        AgentState.crashed,
        AgentState.blocked,
        AgentState.working,
        AgentState.idle,
    ):
        n = getattr(stats, state.name, 0)
        if n:
            prompt_parts.append(f"{STATE_GLYPH.get(state, '?')}{n}")
    prompt = (
        f"Agent state ({' '.join(prompt_parts)}) > "
        if prompt_parts
        else "Agent state > "
    )

    chooser_input = "\n".join(f"{target}\t{label}" for target, label in formatted)
    env = {k: v for k, v in os.environ.items() if not k.startswith("FZF_DEFAULT_OPTS")}
    selection = subprocess.run(
        [
            fzf,
            "--delimiter",
            "\t",
            "--with-nth",
            "2..",
            "--prompt",
            prompt,
            "--border",
            "--no-sort",
            "--layout",
            "reverse",
            "--ansi",
            "--bind",
            "enter:accept",
            "--no-select-1",
            "--no-exit-0",
        ],
        input=chooser_input,
        text=True,
        stdout=subprocess.PIPE,
        env=env,
    )
    if selection.returncode != 0 or not selection.stdout.strip():
        return 0

    target = selection.stdout.strip().split("\t", 1)[0].strip()
    resolved = resolve_target(target)
    if resolved is None:
        return 0
    sid, wid = resolved
    tmux(["switch-client", "-t", f"{sid}:{wid}"], check=False)
    clear_target(sid, wid)
    return 0


# ---------- argparse ----------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)

    notify = sub.add_parser(
        "notify", help="Record a new attention event for the current tmux window"
    )
    notify.add_argument(
        "--pane", help="Explicit tmux pane target (defaults to TMUX_PANE)"
    )
    notify.add_argument("--source", help="Event source, e.g. codex/opencode/pi")
    notify.add_argument("--event-type", help="Event type")
    notify.add_argument("--title", help="Event title")
    notify.add_argument("--message", help="Event message")
    notify.set_defaults(func=cmd_notify)

    event = sub.add_parser(
        "event", help="Record a state event (called by pi extension)"
    )
    event.add_argument("--window", required=True, help="tmux window id")
    event.add_argument(
        "--state",
        required=True,
        choices=["working", "blocked", "cleared"],
        help="Agent state",
    )
    event.add_argument("--pid", type=int, default=None, help="Agent process pid")
    event.set_defaults(func=cmd_event)

    sub.add_parser("status", help="Render status-right segment").set_defaults(
        func=cmd_status
    )

    sub.add_parser(
        "menu", help="Open chooser for attention windows and jump"
    ).set_defaults(func=cmd_menu)

    clear_current = sub.add_parser(
        "clear-current", help="Clear attention for current window"
    )
    clear_current.add_argument(
        "--pane",
        help=(
            "Explicit tmux pane target (defaults to TMUX_PANE or controlling "
            "TTY). Tmux hooks should pass --pane #{pane_id} so the script can "
            "resolve the focused pane without env inheritance."
        ),
    )
    clear_current.set_defaults(func=cmd_clear_current)

    clear_t = sub.add_parser("clear-target", help="Clear attention for explicit target")
    clear_t.add_argument(
        "target", help="Target in the form <session_id>:<window_id> or <window_id>"
    )
    clear_t.set_defaults(func=cmd_clear_target)

    return parser


def main() -> int:
    args = build_parser().parse_args()
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
