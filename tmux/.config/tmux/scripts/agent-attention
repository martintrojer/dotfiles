#!/usr/bin/env python3
"""Track AI agent notifications per tmux window and surface attention in tmux UI."""

from __future__ import annotations

import argparse
import contextlib
import fcntl
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
from collections import Counter, defaultdict
from pathlib import Path
from typing import Iterator, Optional

STATE_DIR = (
    Path(os.environ.get("XDG_STATE_HOME") or Path.home() / ".local" / "state")
    / "tmux-agent-attention"
)
PENDING_FILE = STATE_DIR / "pending.jsonl"
MAX_EVENTS = 4000
DISABLE_SYSTEM_NOTIFY_ENV = "TMUX_AGENT_ATTENTION_DISABLE_SYSTEM_NOTIFY"


# ---------- tmux helpers ----------


def tmux_exists() -> bool:
    return shutil.which("tmux") is not None


def tmux(args: list[str], check: bool = True) -> str:
    # Respect TMUX_SOCKET_NAME / TMUX_SOCKET_PATH so test harnesses can
    # point the script at an isolated server. Real tmux subprocesses
    # already inherit the right TMUX env, so this only matters for
    # tests and CI.
    cmd = ["tmux"]
    socket_name = os.environ.get("TMUX_SOCKET_NAME")
    socket_path = os.environ.get("TMUX_SOCKET_PATH")
    if socket_path:
        cmd += ["-S", socket_path]
    elif socket_name:
        cmd += ["-L", socket_name]
    result = subprocess.run([*cmd, *args], capture_output=True, text=True)
    if check and result.returncode != 0:
        msg = result.stderr.strip() or result.stdout.strip() or "tmux command failed"
        raise RuntimeError(msg)
    return result.stdout.strip()


def tmux_query(target: Optional[str], fields: list[str]) -> Optional[list[str]]:
    """Run display-message with a list of #{...} fields, return parts or None."""
    fmt = "\t".join(fields)
    args = ["display-message", "-p"]
    if target:
        args += ["-t", target]
    args.append(fmt)
    out = tmux(args, check=False)
    if not out:
        return None
    parts = out.split("\t")
    return parts if len(parts) == len(fields) else None


def sanitize(value: str) -> str:
    return value.replace("\t", " ").replace("\n", " ").replace("\r", " ").strip()


def to_int(value: object, default: int = 0) -> int:
    try:
        return int(str(value))
    except (TypeError, ValueError):
        return default


# ---------- pane resolution ----------


def find_tty() -> Optional[str]:
    """Resolve the controlling TTY for the current process.

    Fast path: ``os.ttyname(fd)`` for stdin/stdout/stderr — zero forks when
    the script is run interactively or from a tmux pane that inherited a
    TTY on at least one standard fd.

    Slow path: walk up the process tree via ``ps``, used for hook
    subprocesses (systemd, agent harnesses) where none of fd0/1/2 is a TTY.
    Each ``ps`` invocation is two forks; we cap the walk at 8 levels.

    On macOS ``ps -o tty=`` outputs ``??`` for processes with no controlling
    tty (Linux uses ``?``). Treat any all-``?`` value as no-tty.
    """
    for fd in (0, 1, 2):
        try:
            return os.ttyname(fd)
        except OSError:
            continue

    pid = str(os.getpid())
    for _ in range(8):
        try:
            ppid = subprocess.run(
                ["ps", "-p", pid, "-o", "ppid="], capture_output=True, text=True
            ).stdout.strip()
            if not ppid:
                return None
            tty = subprocess.run(
                ["ps", "-p", ppid, "-o", "tty="], capture_output=True, text=True
            ).stdout.strip()
            if tty and tty.strip("?"):
                return f"/dev/{tty}"
            pid = ppid
        except OSError:
            return None
    return None


def pane_from_tty() -> Optional[str]:
    """Map controlling TTY → tmux pane id (first match wins)."""
    tty = find_tty()
    if not tty:
        return None
    out = tmux(["list-panes", "-a", "-F", "#{pane_tty}\t#{pane_id}"], check=False)
    for row in out.splitlines():
        parts = row.split("\t", 1)
        if len(parts) == 2 and parts[0] == tty:
            return parts[1]
    return None


CONTEXT_FIELDS = [
    "#{session_id}",
    "#{session_name}",
    "#{window_id}",
    "#{window_index}",
    "#{window_name}",
    "#{pane_id}",
    "#{pane_active}",
    "#{window_active}",
    "#{session_attached}",
]
CONTEXT_KEYS = [
    "session_id",
    "session_name",
    "window_id",
    "window_index",
    "window_name",
    "pane_id",
    "pane_active",
    "window_active",
    "session_attached",
]


def current_context(pane: Optional[str]) -> Optional[dict[str, str]]:
    target = pane or os.environ.get("TMUX_PANE") or pane_from_tty()
    if not target:
        return None
    parts = tmux_query(target, CONTEXT_FIELDS)
    return dict(zip(CONTEXT_KEYS, parts)) if parts else None


def is_focused_pane(ctx: dict[str, str]) -> bool:
    """True only if a real user is currently looking at this pane.

    Requires: pane active in window, window active in session, and the
    session has at least one attached client (otherwise an agent in a
    detached session would silently skip the badge).
    """
    return (
        ctx.get("pane_active") == "1"
        and ctx.get("window_active") == "1"
        and to_int(ctx.get("session_attached", "0")) > 0
    )


# ---------- pending events store ----------
#
# Concurrency model: the file is JSONL, one event per line. The notify hot
# path (`append_event`) does a single `O_APPEND` write of one line, which is
# atomic w.r.t. concurrent appends on POSIX local filesystems for writes
# below PIPE_BUF (~4 KB) — a single JSON event fits easily. The
# truncate-rewrite paths (`save_events`, `prune_stale_events`,
# `clear_events_for_target`) use a `.lock` sidecar guarded by `fcntl.flock`
# and write to a tempfile + atomic rename, so concurrent appends and
# rewrites can't interleave or leave a half-written file behind.

LOCK_FILE = PENDING_FILE.with_suffix(PENDING_FILE.suffix + ".lock")


@contextlib.contextmanager
def _events_lock() -> Iterator[None]:
    """Hold an exclusive flock on the sidecar lock file for the duration.

    The lock lives on a sidecar (not on PENDING_FILE itself) so that the
    truncate-rewrite path can rename the data file underneath without
    invalidating the lock fd held by other waiters.
    """
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    fd = os.open(LOCK_FILE, os.O_RDWR | os.O_CREAT, 0o600)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        yield
    finally:
        try:
            fcntl.flock(fd, fcntl.LOCK_UN)
        finally:
            os.close(fd)


def load_events() -> list[dict[str, object]]:
    if not PENDING_FILE.exists():
        return []
    events: list[dict[str, object]] = []
    with PENDING_FILE.open("r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                parsed = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(parsed, dict):
                events.append(parsed)
    return events


def append_event(event: dict[str, object]) -> None:
    """Atomically append a single event to the JSONL store.

    Uses ``O_APPEND`` so concurrent notifies from multiple panes can't
    overwrite each other. No flock is needed for the append itself; the
    lock only matters for truncate-rewrite paths that may run in parallel.
    """
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    line = json.dumps(event, separators=(",", ":")) + "\n"
    fd = os.open(PENDING_FILE, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
    try:
        os.write(fd, line.encode("utf-8"))
    finally:
        os.close(fd)


def _rewrite_events_locked(events: list[dict[str, object]]) -> None:
    """Truncate-rewrite the store via tempfile + atomic rename.

    Caller must hold ``_events_lock()``. Trims to ``MAX_EVENTS`` retaining
    the most recent entries.
    """
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    fd, tmp_path = tempfile.mkstemp(
        prefix=PENDING_FILE.name + ".", suffix=".tmp", dir=str(STATE_DIR)
    )
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            for event in events[-MAX_EVENTS:]:
                f.write(json.dumps(event, separators=(",", ":")) + "\n")
        os.replace(tmp_path, PENDING_FILE)
    except BaseException:
        with contextlib.suppress(OSError):
            os.unlink(tmp_path)
        raise


def save_events(events: list[dict[str, object]]) -> None:
    """Replace the entire store with ``events``. Locks; safe under contention."""
    with _events_lock():
        _rewrite_events_locked(events)


def list_existing_targets() -> set[tuple[str, str]]:
    out = tmux(["list-windows", "-a", "-F", "#{session_id}\t#{window_id}"], check=False)
    targets: set[tuple[str, str]] = set()
    for row in out.splitlines():
        parts = row.split("\t", 1)
        if len(parts) == 2 and parts[0] and parts[1]:
            targets.add((parts[0], parts[1]))
    return targets


def prune_stale_events() -> list[dict[str, object]]:
    with _events_lock():
        events = load_events()
        if not events:
            return events
        targets = list_existing_targets()
        if not targets:
            _rewrite_events_locked([])
            return []
        filtered = [
            e
            for e in events
            if (str(e.get("session_id", "")), str(e.get("window_id", ""))) in targets
        ]
        if len(filtered) != len(events):
            _rewrite_events_locked(filtered)
        return filtered


def clear_events_for_target(session_id: Optional[str], window_id: str) -> None:
    with _events_lock():
        events = load_events()
        filtered = [
            e
            for e in events
            if str(e.get("window_id")) != window_id
            or (session_id is not None and str(e.get("session_id")) != session_id)
        ]
        if len(filtered) != len(events):
            _rewrite_events_locked(filtered)


# ---------- notifications ----------


def parse_notify_fields(args: argparse.Namespace) -> dict[str, str]:
    payload: dict[str, str] = {}
    if not sys.stdin.isatty():
        raw = sys.stdin.read().strip()
        if raw:
            try:
                parsed = json.loads(raw)
                if isinstance(parsed, dict):
                    for key in ("source", "type", "title", "message"):
                        value = parsed.get(key)
                        if value is not None:
                            payload[key] = sanitize(str(value))
            except json.JSONDecodeError:
                payload["message"] = sanitize(raw)

    source = args.source or payload.get("source") or "agent"
    event_type = args.event_type or payload.get("type") or "attention"
    return {
        "source": sanitize(source),
        "type": sanitize(event_type),
        "title": sanitize(args.title or payload.get("title") or source),
        "message": sanitize(args.message or payload.get("message") or event_type),
    }


def send_osc777(title: str, message: str) -> None:
    """Emit OSC 777 to the controlling TTY, wrapping in DCS passthrough inside tmux."""
    tty = find_tty()
    if not tty:
        return
    osc = f"\x1b]777;notify;{title};{message}\x07"
    if os.environ.get("TMUX"):
        osc = f"\x1bPtmux;\x1b{osc}\x1b\\"
    try:
        with open(tty, "w") as f:
            f.write(osc)
    except OSError:
        pass


def send_system_notification(fields: dict[str, str]) -> None:
    if os.environ.get(DISABLE_SYSTEM_NOTIFY_ENV, "").strip().lower() in {
        "1",
        "true",
        "yes",
        "on",
    }:
        return

    title = fields.get("title") or "Agent notification"
    message = fields.get("message", "")
    source = fields.get("source", "")
    event_type = fields.get("type", "")
    if source or event_type:
        prefix = f"[{source}/{event_type}]".strip("/")
        message = f"{prefix} {message}".strip()
    icon_title = f"🤖 {title}"

    osascript = shutil.which("osascript")
    notify_send = shutil.which("notify-send")
    try:
        if osascript:
            qt = json.dumps(icon_title)
            qm = json.dumps(message)
            subprocess.run(
                [osascript, "-e", f"display notification {qm} with title {qt}"],
                check=False,
                capture_output=True,
                text=True,
            )
        elif notify_send:
            subprocess.run(
                [notify_send, icon_title, message],
                check=False,
                capture_output=True,
                text=True,
            )
    except OSError:
        pass


# ---------- attention state on tmux side ----------


def set_attention_flag(window_id: str, on: bool) -> None:
    if on:
        tmux(
            ["set-window-option", "-q", "-t", window_id, "@agent_attention", "1"],
            check=False,
        )
    else:
        tmux(
            ["set-window-option", "-qu", "-t", window_id, "@agent_attention"],
            check=False,
        )


def clear_target(session_id: Optional[str], window_id: str) -> None:
    set_attention_flag(window_id, False)
    clear_events_for_target(session_id, window_id)
    tmux(["refresh-client", "-S"], check=False)


def resolve_target(target: str) -> Optional[tuple[Optional[str], str]]:
    target = target.strip()
    if not target:
        return None
    if ":" in target:
        sid, wid = target.split(":", 1)
        return (sid, wid) if sid and wid else None
    if target.startswith("@"):
        return None, target
    return None


# ---------- subcommands ----------


def cmd_notify(args: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    ctx = current_context(args.pane)
    if ctx is None:
        return 0

    fields = parse_notify_fields(args)

    # Skip the badge only if a user is genuinely focused on this pane.
    if is_focused_pane(ctx):
        send_system_notification(fields)
        return 0

    event: dict[str, object] = {"ts": int(time.time()), **ctx, **fields}
    append_event(event)

    set_attention_flag(ctx["window_id"], True)
    send_system_notification(fields)
    send_osc777(
        fields.get("title", "Agent"), fields.get("message", "Waiting for input")
    )
    tmux(["refresh-client", "-S"], check=False)
    return 0


def cmd_status(_: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    events = prune_stale_events()
    if not events:
        return 0
    windows = {
        (str(e.get("session_id", "")), str(e.get("window_id", ""))) for e in events
    }
    print(len(windows), end="")
    return 0


def cmd_clear_current(args: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    # Tmux hooks run as a server subprocess, so TMUX_PANE is not set and
    # find_tty() can't resolve the focused pane. The hooks pass the
    # target pane explicitly via --pane #{pane_id}.
    ctx = current_context(args.pane)
    if ctx is None:
        return 0
    clear_target(ctx["session_id"], ctx["window_id"])
    return 0


def cmd_clear_target(args: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    resolved = resolve_target(args.target)
    if resolved is None:
        return 1
    clear_target(*resolved)
    return 0


# ---------- menu ----------


def format_relative(ts: int) -> str:
    if ts <= 0:
        return ""
    age = max(0, int(time.time()) - ts)
    if age < 60:
        return f"{age}s"
    if age < 3600:
        return f"{age // 60}m"
    if age < 86400:
        return f"{age // 3600}h"
    return f"{age // 86400}d"


def attention_windows() -> list[dict[str, str]]:
    out = tmux(
        [
            "list-windows",
            "-a",
            "-F",
            "#{session_id}\t#{session_name}\t#{window_id}\t#{window_index}\t#{window_name}\t#{?@agent_attention,1,0}",
        ],
        check=False,
    )
    windows: list[dict[str, str]] = []
    for row in out.splitlines():
        parts = row.split("\t")
        if len(parts) == 6 and parts[5] == "1":
            windows.append(
                {
                    "session_id": parts[0],
                    "session_name": parts[1],
                    "window_id": parts[2],
                    "window_index": parts[3],
                    "window_name": parts[4],
                }
            )
    return windows


def build_menu_rows() -> list[tuple[str, str]]:
    """Return [(target, label)] rows for the picker, sorted by recency then count."""
    prune_stale_events()
    summary: dict[tuple[str, str], dict[str, object]] = defaultdict(
        lambda: {"count": 0, "last_ts": 0, "msg": "", "src": "", "type": ""}
    )
    for event in load_events():
        sid = str(event.get("session_id", ""))
        wid = str(event.get("window_id", ""))
        if not sid or not wid:
            continue
        item = summary[(sid, wid)]
        item["count"] = to_int(item["count"]) + 1
        ts = to_int(event.get("ts", 0))
        if ts >= to_int(item["last_ts"]):
            item["last_ts"] = ts
            item["msg"] = sanitize(str(event.get("message", "")))
            item["src"] = str(event.get("source", "")).strip()
            item["type"] = str(event.get("type", "")).strip()

    rows: list[tuple[str, str, int, int]] = []
    for window in attention_windows():
        sid, wid = window["session_id"], window["window_id"]
        details = summary.get((sid, wid), {})
        count = to_int(details.get("count", 0))
        last_ts = to_int(details.get("last_ts", 0))
        src, etype = str(details.get("src", "")), str(details.get("type", ""))
        msg = str(details.get("msg", ""))
        if len(msg) > 80:
            msg = f"{msg[:77]}..."
        hint = f"{src}/{etype}" if src or etype else "event"
        label = (
            f"[{count:>2}] {window['session_name']}:{window['window_index']} "
            f"{window['window_name']} | {hint} | {format_relative(last_ts):>3} | {msg}"
        )
        rows.append((f"{sid}:{wid}", label, last_ts, count))

    rows.sort(key=lambda item: (-item[2], -item[3], item[1]))
    return [(target, label) for target, label, _, _ in rows]


def cmd_sessions(_: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    prune_stale_events()
    counts = Counter(
        session_name
        for window in attention_windows()
        if (session_name := window.get("session_name", "").strip())
    )
    for session_name in sorted(counts):
        print(f"{session_name}\t{counts[session_name]}")
    return 0


def cmd_menu(_: argparse.Namespace) -> int:
    if not tmux_exists():
        return 0
    rows = build_menu_rows()
    if not rows:
        print("No windows need attention.")
        return 0

    fzf = shutil.which("fzf")
    if fzf is None:
        for _target, label in rows:
            print(label)
        return 0

    chooser_input = "\n".join(f"{target}\t{label}" for target, label in rows)
    env = {k: v for k, v in os.environ.items() if not k.startswith("FZF_DEFAULT_OPTS")}
    selection = subprocess.run(
        [
            fzf,
            "--delimiter",
            "\t",
            "--with-nth",
            "2..",
            "--prompt",
            "Agent attention > ",
            "--border",
            "--no-sort",
            "--layout",
            "reverse",
            "--bind",
            "enter:accept",
            "--no-select-1",
            "--no-exit-0",
        ],
        input=chooser_input,
        text=True,
        stdout=subprocess.PIPE,
        env=env,
    )
    if selection.returncode != 0 or not selection.stdout.strip():
        return 0

    target = selection.stdout.strip().split("\t", 1)[0].strip()
    resolved = resolve_target(target)
    if resolved is None:
        return 0
    sid, wid = resolved
    tmux(["switch-client", "-t", f"{sid}:{wid}"], check=False)
    clear_target(sid, wid)
    return 0


# ---------- argparse ----------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)

    notify = sub.add_parser(
        "notify", help="Record a new attention event for the current tmux window"
    )
    notify.add_argument(
        "--pane", help="Explicit tmux pane target (defaults to TMUX_PANE)"
    )
    notify.add_argument("--source", help="Event source, e.g. claude/codex/opencode/pi")
    notify.add_argument("--event-type", help="Event type")
    notify.add_argument("--title", help="Event title")
    notify.add_argument("--message", help="Event message")
    notify.set_defaults(func=cmd_notify)

    sub.add_parser("status", help="Render status-right segment").set_defaults(
        func=cmd_status
    )

    sub.add_parser(
        "sessions", help="List sessions with pending attention counts"
    ).set_defaults(func=cmd_sessions)

    sub.add_parser(
        "menu", help="Open chooser for attention windows and jump"
    ).set_defaults(func=cmd_menu)

    clear_current = sub.add_parser(
        "clear-current", help="Clear attention for current window"
    )
    clear_current.add_argument(
        "--pane",
        help=(
            "Explicit tmux pane target (defaults to TMUX_PANE or controlling "
            "TTY). Tmux hooks should pass --pane #{pane_id} so the script can "
            "resolve the focused pane without env inheritance."
        ),
    )
    clear_current.set_defaults(func=cmd_clear_current)

    clear_t = sub.add_parser("clear-target", help="Clear attention for explicit target")
    clear_t.add_argument(
        "target", help="Target in the form <session_id>:<window_id> or <window_id>"
    )
    clear_t.set_defaults(func=cmd_clear_target)

    return parser


def main() -> int:
    args = build_parser().parse_args()
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
