#!/usr/bin/env bash
set -euo pipefail

session_env=(
  DISPLAY
  WAYLAND_DISPLAY
  XDG_CURRENT_DESKTOP
  XDG_SESSION_TYPE
  NIRI_SOCKET
)

# Make the compositor session environment visible to user services and portals.
systemctl --user import-environment "${session_env[@]}" || true

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd "${session_env[@]}" >/dev/null 2>&1 || true
fi

# Start niri-session.target only after niri is accepting IPC requests.
for _ in $(seq 1 100); do
  if niri msg -j workspaces >/dev/null 2>&1; then
    exec systemctl --user start niri-session.target
  fi

  sleep 0.1
done

exec systemctl --user start niri-session.target
