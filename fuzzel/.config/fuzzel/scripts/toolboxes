#!/usr/bin/env python3
"""Toolbox selector from `toolbox list --containers`."""

from __future__ import annotations

import argparse
import re

from _common import (
    ScriptError,
    cli_main,
    fuzzel_dmenu,
    notify,
    picker_cache_path,
    require_commands,
    run,
)


def parse_args() -> argparse.Namespace:

    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--prompt", default="Toolbx  ")
    parser.add_argument("--width", type=int, default=45)
    parser.add_argument("--terminal", default="alacritty")
    return parser.parse_args()


def parse_toolboxes(output: str) -> list[tuple[str, str]]:
    toolboxes: list[tuple[str, str]] = []
    for raw in output.splitlines():
        line = raw.strip()
        if not line or line.startswith("CONTAINER ID"):
            continue

        columns = re.split(r"\s{2,}", line)
        if len(columns) < 4:
            continue

        name = columns[1].strip()
        status = columns[3].strip()
        if name:
            toolboxes.append((name, status))

    return sorted(toolboxes, key=lambda item: item[0])


def main() -> int:
    args = parse_args()
    require_commands(["fuzzel", args.terminal, "toolbox"])

    result = run(["toolbox", "list", "--containers"], check=False)
    if result.returncode != 0:
        message = result.stderr.strip() or "Failed to list toolboxes"
        notify("Toolboxes", message)
        raise ScriptError(message)

    toolboxes = parse_toolboxes(result.stdout)
    if not toolboxes:
        notify("Toolboxes", "No toolboxes found")
        raise ScriptError("No toolboxes found")

    cache = picker_cache_path("toolboxes")
    options = [f"{name:<20} {status}" for name, status in toolboxes]
    selection = fuzzel_dmenu(
        prompt=args.prompt, width=args.width, cache=cache, options=options
    )
    if not selection:
        return 0

    name = selection.split()[0]
    run([args.terminal, "-e", "toolbox", "enter", name], check=False)
    return 0


if __name__ == "__main__":
    cli_main("toolboxes", main)
