#!/usr/bin/env python3
"""Show Sway keybindings in a fuzzel picker and execute the chosen one.

Parses ``~/.config/sway/config`` for ``bindsym`` lines, presents them as a
fuzzel picker, and dispatches the selected action via ``swaymsg``. Sway treats
any ``bindsym`` action as a sway command, so feeding the action verbatim to
``swaymsg`` reproduces what pressing the keystroke would have done — including
``exec`` invocations, ``mode`` switches, ``floating toggle``, and so on.
"""

from __future__ import annotations

import argparse
import os
import re
from pathlib import Path

from _common import (
    ScriptError,
    cli_main,
    fuzzel_dmenu,
    notify,
    picker_cache_path,
    require_commands,
    run,
)

DEFAULT_CONFIG = (
    f"{os.environ.get('XDG_CONFIG_HOME', str(Path.home() / '.config'))}/sway/config"
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", default=DEFAULT_CONFIG, help="Path to sway config")
    parser.add_argument("--prompt", default="Hotkeys  ")
    parser.add_argument("--width", type=int, default=90)
    parser.add_argument("--lines", type=int, default=20)
    parser.add_argument("--key-width", type=int, default=24)
    parser.add_argument(
        "--no-exec",
        action="store_true",
        help="Show the picker but do not run the selected binding (read-only mode).",
    )
    return parser.parse_args()


def parse_bind_entries(config_path: Path, key_width: int) -> list[tuple[str, str]]:
    """Return ``(label, action)`` pairs for every ``bindsym`` line in the config.

    ``label`` is what the picker shows; ``action`` is the raw sway command
    suitable for ``swaymsg``.
    """
    entries: list[tuple[str, str]] = []
    for raw in config_path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line.startswith("bindsym "):
            continue
        parts = line.split(None, 2)
        if len(parts) < 3:
            continue
        # Skip flag-form bindsyms (--release etc.) for now; they're rare here
        # and the action position shifts.
        key = parts[1]
        action = re.sub(r"\s+", " ", parts[2]).strip()
        if key.startswith("--") or action.startswith("--"):
            continue
        display_key = key.replace("$mod", "Mod")
        entries.append((f"{display_key:<{key_width}} {action}", action))
    return entries


def execute_action(action: str) -> int:
    """Dispatch a sway command via ``swaymsg``.

    Returns the swaymsg exit code so callers can surface failures.
    """
    if not action:
        return 0
    result = run(["swaymsg", "--", action], check=False)
    if result.returncode != 0:
        stderr = (result.stderr or "").strip()
        notify("Hotkeys", f"swaymsg failed: {stderr or action}")
    return result.returncode


def main() -> int:
    args = parse_args()
    require_commands(["fuzzel", "swaymsg"])

    config_path = Path(args.config)
    if not config_path.is_file():
        raise ScriptError(f"sway config not found: {config_path}")

    entries = parse_bind_entries(config_path, args.key_width)
    if not entries:
        notify("Hotkeys", "No bindsym entries found")
        return 0

    label_to_action = dict(entries)
    selected = fuzzel_dmenu(
        prompt=args.prompt,
        width=args.width,
        lines=args.lines,
        cache=picker_cache_path("hotkeys"),
        options=(label for label, _ in entries),
    )
    if not selected:
        return 0

    # Free-text Enter in fuzzel returns the typed string verbatim; if it
    # doesn't match a known label we surface the failure to the user rather
    # than silently dispatching the wrong action.
    action = label_to_action.get(selected)
    if action is None:
        notify("Hotkeys", "Could not resolve selected entry to an action")
        return 1

    if args.no_exec:
        print(action)
        return 0

    return execute_action(action)


if __name__ == "__main__":
    cli_main("hotkeys", main)
