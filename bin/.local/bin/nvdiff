#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: nvdiff <left> <right>" >&2
  exit 2
fi

if [[ -r /dev/tty ]]; then
  exec </dev/tty >/dev/tty 2>/dev/tty
fi

NVIM_DIFFTOOL_LEFT=$1 \
NVIM_DIFFTOOL_RIGHT=$2 \
  exec nvim \
    -c "lua require('difftool').open(vim.env.NVIM_DIFFTOOL_LEFT, vim.env.NVIM_DIFFTOOL_RIGHT)" \
    --
