#!/usr/bin/env python3
"""Waybar temperature summary for CPU/GPU with detailed sensor tooltip."""

from __future__ import annotations

import json
from dataclasses import dataclass
from pathlib import Path

HWMON_ROOT = Path("/sys/class/hwmon")

ICON_TEMP = ""
ICON_CPU = "󰘚"
ICON_GPU = "󰢮"
ICON_BOARD = "󰋊"
ICON_NVME = "󰋊"

DEVICE_TITLES = {
    "k10temp": f"{ICON_CPU} CPU",
    "amdgpu": f"{ICON_GPU} GPU",
    "gigabyte_wmi": f"{ICON_BOARD} Motherboard",
    "nvme": f"{ICON_NVME} NVMe",
}


@dataclass(frozen=True)
class Hwmon:
    name: str
    path: Path


def read_text(path: Path) -> str | None:
    try:
        return path.read_text().strip()
    except FileNotFoundError:
        return None


def temp_c(path: Path) -> int | None:
    value = read_text(path)
    if value is None:
        return None
    try:
        return round(int(value) / 1000)
    except ValueError:
        return None


def label(path: Path, fallback: str) -> str:
    return read_text(path) or fallback


def hwmons() -> dict[str, Hwmon]:
    devices = {}
    for path in sorted(HWMON_ROOT.glob("hwmon*")):
        name = read_text(path / "name")
        if name and name not in devices:
            devices[name] = Hwmon(name=name, path=path)
    return devices


def sensor_value(
    device: Hwmon | None, wanted_label: str, fallback_input: str = "temp1_input"
) -> int | None:
    if device is None:
        return None

    for temp_input in sorted(device.path.glob("temp*_input")):
        idx = temp_input.name.removeprefix("temp").removesuffix("_input")
        if label(device.path / f"temp{idx}_label", "") == wanted_label:
            return temp_c(temp_input)

    return temp_c(device.path / fallback_input)


def sensor_lines(title: str, device: Hwmon | None) -> list[str]:
    if device is None:
        return []

    rows = []
    for temp_input in sorted(device.path.glob("temp*_input")):
        idx = temp_input.name.removeprefix("temp").removesuffix("_input")
        value = temp_c(temp_input)
        if value is None:
            continue
        rows.append(
            f"{label(device.path / f'temp{idx}_label', f'temp{idx}')}: {value}°C"
        )

    if not rows:
        return []
    return [title, *rows]


def main() -> int:
    devices = hwmons()
    cpu = devices.get("k10temp")
    gpu = devices.get("amdgpu")

    cpu_tctl = sensor_value(cpu, "Tctl")
    gpu_edge = sensor_value(gpu, "edge")

    text_parts = []
    if cpu_tctl is not None:
        text_parts.append(f"{cpu_tctl}°")
    if gpu_edge is not None:
        text_parts.append(f"{gpu_edge}°")

    tooltip_sections = []
    for name in ("k10temp", "amdgpu", "gigabyte_wmi", "nvme"):
        lines = sensor_lines(DEVICE_TITLES[name], devices.get(name))
        if lines:
            tooltip_sections.append("\n".join(lines))

    classes = []
    if any(value is not None and value >= 90 for value in (cpu_tctl, gpu_edge)):
        classes.append("critical")
    elif any(value is not None and value >= 80 for value in (cpu_tctl, gpu_edge)):
        classes.append("warning")

    output = {
        "text": f"{ICON_TEMP} {' '.join(text_parts)}"
        if text_parts
        else f"{ICON_TEMP} n/a",
        "tooltip": "\n\n".join(tooltip_sections)
        if tooltip_sections
        else "Temperature sensors unavailable",
        "class": classes,
    }
    print(json.dumps(output, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
