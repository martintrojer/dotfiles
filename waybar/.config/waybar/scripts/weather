#!/usr/bin/env bash

# Waybar weather module, adapted from Omarchy's wttr.in helpers.
# Set WTTR_LOCATION to pin a location; otherwise wttr.in guesses from IP.

set -o pipefail

DEFAULT_WEATHER_ICON="َ°–گ"

weather_url() {
  if [[ -n ${WTTR_LOCATION:-} ]]; then
    printf 'https://wttr.in/%s' "$WTTR_LOCATION"
  else
    printf 'https://wttr.in'
  fi
}

weather_status() {
  local weather place temperature wind condition
  weather=$(curl -fsS --connect-timeout 2 --max-time 8 "$(weather_url)?format=%l|%t|%w|%C" 2>/dev/null | tr -d '\n') || return 1

  [[ -n $weather ]] || return 1

  IFS='|' read -r place temperature wind condition <<< "$weather"
  place=${place%%,*}
  place=${place^}
  temperature=${temperature#+}

  printf '%s  آ·  %s  آ·  Wind %s  آ·  %s\n' "$place" "$temperature" "$wind" "$condition"
}

weather_icon() {
  local weather_data weather_code sunrise sunset now_epoch sunrise_epoch sunset_epoch night icon

  weather_data=$(curl -fsS --connect-timeout 2 --max-time 8 "$(weather_url)?format=j1" 2>/dev/null \
    | jq -er '[.current_condition[0].weatherCode, .weather[0].astronomy[0].sunrise, .weather[0].astronomy[0].sunset] | select(all(. != null and . != "")) | @tsv' 2>/dev/null) || return 1

  IFS=$'\t' read -r weather_code sunrise sunset <<< "$weather_data"
  if [[ ! $weather_code =~ ^[0-9]+$ || ! $sunrise =~ ^[0-9]{1,2}:[0-9]{2}\ [AP]M$ || ! $sunset =~ ^[0-9]{1,2}:[0-9]{2}\ [AP]M$ ]]; then
    return 1
  fi

  now_epoch=$(date +%s)
  sunrise_epoch=$(date -d "today $sunrise" +%s 2>/dev/null || echo 0)
  sunset_epoch=$(date -d "today $sunset" +%s 2>/dev/null || echo 0)

  if (( sunrise_epoch > 0 && sunset_epoch > 0 && (now_epoch < sunrise_epoch || now_epoch >= sunset_epoch) )); then
    night=true
  else
    night=false
  fi

  case $weather_code in
    113) [[ $night == true ]] && icon="َ°–”" || icon="َ°–™" ;;
    116) [[ $night == true ]] && icon="َ°¼±" || icon="َ°–•" ;;
    119|122) icon="َ°–گ" ;;
    143|248|260) icon="َ°–‘" ;;
    176|263|353) [[ $night == true ]] && icon="َ°–”" || icon="َ°–—" ;;
    179|227|230|323|326|368) [[ $night == true ]] && icon="َ°–”" || icon="َ°–ک" ;;
    182|185|281|284|311|314|317|320|350|362|365|374|377) icon="َ°™؟" ;;
    200|386|389|392|395) icon="َ°–“" ;;
    266|293|296|299|302|305|308|356|359) icon="َ°–—" ;;
    329|332|335|338|371) icon="َ°–ک" ;;
    *) icon="َ°–گ" ;;
  esac

  printf '%s\n' "$icon"
}

case ${1:-} in
  --status)
    weather_status || printf 'Weather unavailable\n'
    ;;
  *)
    icon=$(weather_icon 2>/dev/null) || icon="$DEFAULT_WEATHER_ICON"
    status=$(weather_status 2>/dev/null) || status="Weather unavailable"

    if [[ $status == "Weather unavailable" ]]; then
      jq -cn --arg text "$icon" --arg tooltip "$status" '{text: $text, class: "unavailable", tooltip: $tooltip}'
    else
      jq -cn --arg text "$icon" --arg tooltip "$status" '{text: $text, tooltip: $tooltip}'
    fi
    ;;
esac
