anchor=top-right
default-timeout=5000
width=420
outer-margin=20
padding=10,15
border-size=2
border-radius=0
max-icon-size=32
max-history=20
font=JetBrains Mono Nerd Font 16px

# Catppuccin Mocha colors
# THEME BEGIN: mako-colors
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#313244
progress-color=#cba6f7

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[urgency=low]
background-color=#1e1e2e
text-color=#a6adc8
border-color=#313244

[urgency=normal]
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#313244

[urgency=critical]
background-color=#1e1e2e
text-color=#f38ba8
border-color=#f38ba8
default-timeout=0
layer=overlay
# THEME END: mako-colors

# Noisy media-player track-change notifications should be visible briefly but
# must not evict useful notifications from mako history / Waybar's picker.
[app-name=Cider]
default-timeout=1500
history=0

# Agent completion notifications should toast briefly and update tmux's
# agent-attention state, but repeated "waiting for input" reminders should not
# fill mako history / Waybar's notification counter.
[app-name=footclient summary=Pi body="Waiting for input"]
history=0
