background={{mocha.base|nohash}}

# normal
regular0={{mocha.base|nohash}}
regular1={{mocha.red|nohash}}
regular2={{mocha.green|nohash}}
regular3={{mocha.yellow|nohash}}
regular4={{mocha.blue|nohash}}
regular5={{mocha.pink|nohash}}
regular6={{mocha.teal|nohash}}
regular7={{mocha.subtext1|nohash}}

# bright
bright0={{mocha.surface2|nohash}}
bright1={{mocha.red|nohash}}
bright2={{mocha.green|nohash}}
bright3={{mocha.yellow|nohash}}
bright4={{mocha.blue|nohash}}
bright5={{mocha.pink|nohash}}
bright6={{mocha.teal|nohash}}
